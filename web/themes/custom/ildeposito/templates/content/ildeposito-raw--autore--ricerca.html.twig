{#
/**
 * @file
 * Template per la visualizzazione di un'entità in formato raw.
 *
 * Variabili disponibili:
 * - entity: L'entità che viene visualizzata.
 * - entity_type: Il tipo di entità.
 * - data: Array con i dati raw dell'entità.
 * - title: Il titolo dell'entità.
 * - view_mode: La view mode utilizzata.
 * - node: L'oggetto nodo (se l'entità è un nodo).
 *
 * SICUREZZA: Non usare il filtro |raw su nessuna variabile di questo template.
 * L'autoescaping di Twig protegge da XSS nell'output JSON.
 */
#}
{% set classes = [
  'ildeposito-raw',
  'ildeposito-raw--' ~ entity_type,
] %}
<article{{ attributes.addClass(classes).setAttribute('data-view-mode', view_mode) }}>
 <div class="text-lessdark text-uppercase fs-6">
 {{ include('ildeposito:icon', {
        name: 'user',
        class: ['text-lessdark', 'fs-6'],
        type: 'regular',
        size: '1rem',
      }, with_context = false) }}
 Autore</div>
 
  {% if title %}
    <h3 class="font-title text-primary"><a href="{{ path('entity.node.canonical', {'node': entity.id}) }}">{{ title }}</a></h3>
  {% endif %}
 
   <a class="text-lessdark" href="{{ data.localizzazione.0.url }}">{{ data.localizzazione.0.label }}</a>

{{dump(data)}}
</article>