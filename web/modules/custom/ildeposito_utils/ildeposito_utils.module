/**
 * @param $entity \Drupal\Core\Entity\EntityInterface
 * @param $alias
 *
 * @throws \Drupal\Core\Entity\EntityStorageException
 */
function _ildeposito_create_alias(\Drupal\Core\Entity\EntityInterface $entity) {
  $languages = \Drupal::languageManager()->getLanguages();
  $title_clean = \Drupal::service('pathauto.alias_cleaner')
    ->cleanString($entity->label());
  $aliases = _get_node_aliases();
    foreach ($languages as $language) {
      if ($language->getId() != 'it') {
        $base_alias = $aliases[$entity->bundle()][$language->getId()] ?? '/'. $entity->bundle() . '-' . $language->getId();
        if (!empty($base_alias) && !empty($title_clean)) {
          $pathAlias = PathAlias::create([
            'path' => '/node/' . $entity->id(),
            'alias' => $base_alias . '/' . $title_clean,
            'langcode' => $language->getId(),
          ]);
          $pathAlias->save();
        }
      }
    }
  }

function _ildeposito_get_alias_by_path($entity) {
  $query = \Drupal::entityQuery('path_alias')
    ->condition('path', '/node/' . $entity->id())
    ->condition('langcode', 'it', '<>')
    ->accessCheck(TRUE);
  return $query->execute();
}

function _get_node_aliases() {
  $aliases['canto']['en'] = '/songs';
  $aliases['autore']['en'] = '/authors';
  $aliases['traduzione']['en'] = '/translations';

  $aliases['canto']['fr'] = '/songs-fr';
  $aliases['autore']['fr'] = '/authors-fr';
  $aliases['traduzione']['fr'] = '/translations-fr';

  $aliases['canto']['es'] = '/songs-es';
    $aliases['autore']['es'] = '/authors-es';
    $aliases['traduzione']['es'] = '/translations-es';

    // Fallback automatico per tutte le lingue/bundle gestiti.
    $bundles = ['canto', 'autore', 'traduzione'];
    $languages = ['en', 'fr', 'es']; // Estendi se necessario
    foreach ($bundles as $bundle) {
      foreach ($languages as $lang) {
        if (empty($aliases[$bundle][$lang])) {
          $aliases[$bundle][$lang] = '/' . $bundle . '-' . $lang;
        }
      }
    }
    return $aliases;
}

