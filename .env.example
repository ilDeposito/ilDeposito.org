# stage | prod
ENV=stage
COMPOSE_PROJECT_NAME=ildeposito-stage
BASIC_AUTH_USER=LA_MIA_USER
BASIC_AUTH_HASH=LA_MIA_PASSWORD

# Dominio pubblico del frontend, usato dalla label Caddy in frontend/compose.prod.yml
# (solo prod: in stage il dominio resta hardcoded, protetto da basic auth)
FRONTEND_DOMAIN=www.ildeposito.org
# NB: durante il cutover prod, BASIC_AUTH_HASH protegge TEMPORANEAMENTE il
# frontend (frontend/compose.prod.yml) — va tolta da lì al go-live pubblico.
# Il backend admin (admin.ildeposito.org / admin-stage.ildeposito.org) non
# usa più BASIC_AUTH_HASH: è protetto da Authelia forward_auth, vedi
# OPENID_CONNECT_AUTHELIA_CLIENT_ID/SECRET più sotto.

# Drupal
DRUPAL_HASH_SALT=GENERA_CON_drush_php-eval_echo_Drupal_hash_salt

# Database
DB_PASSWORD=UNA_PASSWORD_FORTE
DB_ROOT_PASSWORD=UNA_PASSWORD_FORTE

# GitHub App (ildeposito_build)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=
MAIL_FROM=noreply@ildeposito.org

# Drupal API (utente con ruolo "api" per scrittura JSON:API)
# DRUPAL_API_URL è hardcoded nei compose file (http://drupal-api:80)
DRUPAL_API_USER=api_user
DRUPAL_API_PASS=la_password

# Altcha antispam — chiave master HMAC (generare con: openssl rand -hex 32)
ALTCHA_HMAC_KEY=

# Umami self-hosted (ildeposito_stats). Self-hosted non supporta API key
# (solo Umami Cloud): il client fa login utente/password su /api/auth/login.
# In stage/prod usare l'indirizzo Docker interno del container Umami
# (es. http://ildeposito_stats_umami:3000), NON il dominio pubblico
# stats.ildeposito.org — quel dominio blocca /api/auth/login in Caddy di
# proposito (Umami è dietro SSO Authelia, login nativo disattivato). Il
# servizio php è sulla rete esterna "caddy" apposta per questo (vedi
# backend/compose.yml), quindi può risolvere il nome del container Umami.
# Serve comunque un utente Umami dedicato con permessi di sola lettura, non
# l'account admin.
UMAMI_API_URL=http://ildeposito_stats_umami:3000
UMAMI_USERNAME=
UMAMI_PASSWORD=
UMAMI_WEBSITE_ID=

# Webhook Make.com per il post automatico su FB degli eventi con anniversario
# oggi (ildeposito_utils, drush ildeposito:fb-post, va aggiunto al crontab
# della macchina). Impostare SOLO nel .env di produzione: se assente il
# comando è un no-op, così stage non posta per sbaglio su FB.
FBPOST_WEBHOOK_URL=

# SSO Authelia (openid_connect, client "authelia", generic OIDC).
# client_secret è il segreto IN CHIARO che Drupal invia in fase di scambio
# codice→token; su Authelia (configuration.yml, identity_providers.oidc.clients)
# va registrato l'HASH di questo stesso valore (authelia crypto hash generate
# argon2 --password '...'), non il valore in chiaro.
# redirect_uri da registrare su Authelia (un client OIDC per ambiente,
# CLIENT_ID diverso così una sessione stage non autologga anche su prod):
# - stage: https://admin-stage.ildeposito.org/openid-connect/authelia
# - prod:  https://admin.ildeposito.org/openid-connect/authelia
OPENID_CONNECT_AUTHELIA_CLIENT_ID=drupal-stage   # drupal-prod in produzione
OPENID_CONNECT_AUTHELIA_CLIENT_SECRET=

# Subnet della rete docker "caddy": unico range da cui il nginx frontend
# accetta X-Forwarded-For (modulo real_ip → rate limit per IP reale del
# client). Se troppo ampio, chi origina traffico dal range può falsificare
# l'IP e bypassare i rate limit. Ricavare il valore reale con:
#   docker network inspect caddy --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}'
# NB: se la rete "caddy" viene ricreata la subnet può cambiare.
CADDY_TRUSTED_SUBNET=172.19.0.0/16

