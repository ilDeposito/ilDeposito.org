# stage | prod
ENV=stage
COMPOSE_PROJECT_NAME=ildeposito-stage
BASIC_AUTH_USER=LA_MIA_USER
BASIC_AUTH_HASH=LA_MIA_PASSWORD

# Drupal
DRUPAL_HASH_SALT=GENERA_CON_drush_php-eval_echo_Drupal_hash_salt

# Database
DB_PASSWORD=UNA_PASSWORD_FORTE
DB_ROOT_PASSWORD=UNA_PASSWORD_FORTE

# GitHub App (ildeposito_build)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=
MAIL_FROM=noreply@ildeposito.org

# Drupal API (utente con ruolo "api" per scrittura JSON:API)
# DRUPAL_API_URL è hardcoded nei compose file (http://drupal-api:80)
DRUPAL_API_USER=api_user
DRUPAL_API_PASS=la_password

# Altcha antispam — chiave master HMAC (generare con: openssl rand -hex 32)
ALTCHA_HMAC_KEY=

# Subnet della rete docker "caddy": unico range da cui il nginx frontend
# accetta X-Forwarded-For (modulo real_ip → rate limit per IP reale del
# client). Se troppo ampio, chi origina traffico dal range può falsificare
# l'IP e bypassare i rate limit. Ricavare il valore reale con:
#   docker network inspect caddy --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}'
# NB: se la rete "caddy" viene ricreata la subnet può cambiare.
CADDY_TRUSTED_SUBNET=172.19.0.0/16

