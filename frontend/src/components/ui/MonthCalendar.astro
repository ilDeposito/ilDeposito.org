---
interface Props {
  month: number;
  year: number;
  highlightedDays: number[];
  basePath?: string;
  headingLevel?: 'h2' | 'h3';
}

const { month, year, highlightedDays, basePath = '/archivio/calendario-cantato', headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;

const mesiIT = ['gennaio','febbraio','marzo','aprile','maggio','giugno','luglio','agosto','settembre','ottobre','novembre','dicembre'];
const giorniSettimana = [
  { short: 'L', full: 'lunedì' },
  { short: 'M', full: 'martedì' },
  { short: 'M', full: 'mercoledì' },
  { short: 'G', full: 'giovedì' },
  { short: 'V', full: 'venerdì' },
  { short: 'S', full: 'sabato' },
  { short: 'D', full: 'domenica' },
];

const meseNome = mesiIT[month - 1];
const daysInMonth = new Date(year, month, 0).getDate();

const firstDayRaw = new Date(year, month - 1, 1).getDay();
const startOffset = firstDayRaw === 0 ? 6 : firstDayRaw - 1;

const highlightSet = new Set(highlightedDays);

const days = Array.from({ length: daysInMonth }, (_, i) => i + 1);
const emptyCells = Array.from({ length: startOffset });
---

<div class="flex flex-col gap-1">
  <Heading class="font-serif font-bold text-center text-primary capitalize text-base py-1">
    {meseNome}
  </Heading>
  <div class="grid grid-cols-7 text-center text-sm gap-y-1 gap-x-1">
    {giorniSettimana.map((g) => (
      <span class="font-sans font-semibold text-base-content/70 text-xs py-1.5">
        <span aria-hidden="true">{g.short}</span>
        <span class="sr-only">{g.full}</span>
      </span>
    ))}
    {emptyCells.map(() => <span></span>)}
    {days.map((day) => {
      const hasEvent = highlightSet.has(day);
      return hasEvent ? (
        <a
          href={`${basePath}/${day}-${meseNome}`}
          aria-label={`${day} ${meseNome} — eventi del giorno`}
          class="w-8 h-8 flex items-center justify-center mx-auto font-bold text-primary hover:bg-primary hover:text-primary-content rounded-full transition-colors"
        >
          <span aria-hidden="true">{day}</span>
        </a>
      ) : (
        <span class="w-8 h-8 flex items-center justify-center mx-auto text-base-content/70">{day}</span>
      );
    })}
  </div>
</div>
