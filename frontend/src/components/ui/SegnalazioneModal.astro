---
import Icon from '../base/Icon.astro';

interface Props {
  cantoUrl: string;
}
const { cantoUrl } = Astro.props;
---

<!-- Pulsante flottante fisso in basso a destra -->
<button
  id="segnala-open-btn"
  type="button"
  class="fixed bottom-6 right-6 z-40 btn btn-primary rounded-xl shadow-lg gap-2"
  aria-label="Segnala una modifica a questo canto"
>
  <Icon name="pencil-simple" class="text-lg" />
  <span class="font-semibold text-sm">Modifica</span>
</button>

<!-- Modal segnalazione -->
<dialog id="modal-segnalazione" class="modal">
  <div class="modal-box max-w-lg my-12 max-h-[calc(100vh-6rem)]">
    <form method="dialog" class="absolute right-3 top-3">
      <button class="btn btn-sm btn-circle btn-ghost" aria-label="Chiudi">✕</button>
    </form>

    <div class="flex items-center gap-3 mb-1">
      <Icon name="pencil-simple" class="text-2xl text-primary" />
      <h3 class="font-serif font-bold text-xl">Segnala una modifica</h3>
    </div>
    <p class="text-sm text-base-content/70 mb-5">Hai trovato un errore o vuoi suggerire una correzione a questo canto?</p>

    <div id="segnalazione-error" role="alert" class="alert alert-error mb-5 hidden">
      <Icon name="warning-circle" class="text-xl shrink-0" />
      <span id="segnalazione-error-msg">Si è verificato un errore durante l'invio. Riprova più tardi.</span>
    </div>

    <form id="segnalazione-form" action="/api/modulo_contatti" method="post" class="flex flex-col gap-5" novalidate>

      <!-- Honeypot: campo invisibile compilato solo dai bot -->
      <div aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;">
        <label for="seg-website">Non compilare</label>
        <input type="text" id="seg-website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <input type="hidden" name="titolo" value="Segnalazione canto" />

      <!-- URL canto: visibile ma disabilitato; hidden input porta il valore effettivo -->
      <div class="form-control">
        <label class="label" for="seg-link">
          <span class="label-text font-semibold">Canto</span>
        </label>
        <input
          type="url"
          id="seg-link"
          value={cantoUrl}
          readonly
          class="input input-bordered form-border bg-base-200 w-full opacity-60 cursor-not-allowed"
        />
        <input type="hidden" name="link" value={cantoUrl} />
      </div>

      <div class="form-control">
        <label class="label" for="seg-nome">
          <span class="label-text font-semibold">Nome <span class="text-error" aria-hidden="true">*</span></span>
        </label>
        <input
          type="text"
          id="seg-nome"
          name="nome"
          required
          maxlength="255"
          autocomplete="name"
          aria-describedby="err-seg-nome"
          class="input input-bordered form-border bg-base-200 w-full"
          placeholder="Il tuo nome"
        />
        <p id="err-seg-nome" role="alert" class="text-error text-sm mt-1 hidden"></p>
      </div>

      <div class="form-control">
        <label class="label" for="seg-email">
          <span class="label-text font-semibold">Email <span class="text-error" aria-hidden="true">*</span></span>
        </label>
        <input
          type="email"
          id="seg-email"
          name="email"
          required
          maxlength="254"
          autocomplete="email"
          aria-describedby="err-seg-email"
          class="input input-bordered form-border bg-base-200 w-full"
          placeholder="la-tua@email.it"
        />
        <p id="err-seg-email" role="alert" class="text-error text-sm mt-1 hidden"></p>
      </div>

      <div class="form-control">
        <label class="label" for="seg-messaggio">
          <span class="label-text font-semibold">Segnalazione <span class="text-error" aria-hidden="true">*</span></span>
        </label>
        <textarea
          id="seg-messaggio"
          name="messaggio"
          required
          rows="5"
          aria-describedby="seg-messaggio-hint err-seg-messaggio"
          class="textarea textarea-bordered form-border bg-base-200 w-full font-sans text-base leading-relaxed"
          placeholder="Descrivi l'errore o la correzione suggerita…"
        ></textarea>
        <div class="label">
          <span id="seg-messaggio-hint" class="label-text-alt text-base-content/70">
            <span id="seg-count">0</span>/200 righe (massimo 200 righe)
          </span>
        </div>
        <p id="err-seg-messaggio" role="alert" class="text-error text-sm mt-1 hidden"></p>
      </div>

      <!-- Altcha: auto="onload" forza il solve immediato, necessario dentro un dialog chiuso -->
      <altcha-widget challenge="/api/altcha" hidefooter auto="onload"></altcha-widget>

      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-3" for="seg-privacy">
          <input
            type="checkbox"
            id="seg-privacy"
            name="privacy"
            aria-describedby="err-seg-privacy"
            class="checkbox checkbox-primary form-border shrink-0"
          />
          <span class="label-text">
            Ho letto e accetto la
            <a href="/informazioni/privacy" target="_blank" rel="noopener noreferrer" class="link link-primary font-semibold">Privacy Policy<span class="sr-only"> (si apre in una nuova finestra)</span></a>
            <span class="text-error" aria-hidden="true"> *</span>
          </span>
        </label>
        <p id="err-seg-privacy" role="alert" class="text-error text-sm mt-1 hidden"></p>
      </div>

      <div class="mt-2">
        <button id="seg-submit-btn" type="submit" class="btn btn-primary w-full sm:w-auto">
          <Icon name="paper-plane-tilt" />
          <span id="seg-submit-label">Invia segnalazione</span>
        </button>
      </div>

    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>chiudi</button></form>
</dialog>

<!-- Modal successo -->
<dialog id="modal-segnalazione-ok" class="modal">
  <div class="modal-box">
    <div class="flex items-center gap-3 mb-4">
      <Icon name="check-circle" class="text-3xl text-success" />
      <h3 class="font-serif font-bold text-lg">Segnalazione inviata!</h3>
    </div>
    <p class="font-sans text-base-content/80">
      Grazie per la segnalazione. La esamineremo il prima possibile.
    </p>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-primary">Chiudi</button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>chiudi</button></form>
</dialog>

<script>
  import 'altcha';
</script>

<script is:inline>
(function () {
  const openBtn = document.getElementById('segnala-open-btn');
  const modal = document.getElementById('modal-segnalazione');
  const modalOk = document.getElementById('modal-segnalazione-ok');
  const form = document.getElementById('segnalazione-form');
  const errorBox = document.getElementById('segnalazione-error');
  const errorMsg = document.getElementById('segnalazione-error-msg');
  const submitBtn = document.getElementById('seg-submit-btn');
  const submitLabel = document.getElementById('seg-submit-label');
  const emailInput = document.getElementById('seg-email');
  const privacyCheck = document.getElementById('seg-privacy');
  const messaggioArea = document.getElementById('seg-messaggio');
  const messaggioCount = document.getElementById('seg-count');
  const nomeInput = document.getElementById('seg-nome');

  const fieldErrors = {
    nome: [nomeInput, document.getElementById('err-seg-nome')],
    email: [emailInput, document.getElementById('err-seg-email')],
    messaggio: [messaggioArea, document.getElementById('err-seg-messaggio')],
    privacy: [privacyCheck, document.getElementById('err-seg-privacy')],
  };

  function setFieldError(field, msg) {
    const [input, errEl] = fieldErrors[field];
    input.setAttribute('aria-invalid', 'true');
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
  }

  function clearFieldErrors() {
    Object.values(fieldErrors).forEach(([input, errEl]) => {
      input.removeAttribute('aria-invalid');
      errEl.classList.add('hidden');
      errEl.textContent = '';
    });
  }

  Object.values(fieldErrors).forEach(([input, errEl]) => {
    const clear = () => {
      input.removeAttribute('aria-invalid');
      errEl.classList.add('hidden');
    };
    input.addEventListener('input', clear);
    input.addEventListener('change', clear);
  });

  openBtn.addEventListener('click', function () {
    modal.showModal();
  });

  messaggioArea.addEventListener('input', function () {
    const lines = this.value === '' ? 0 : this.value.split('\n').length;
    messaggioCount.textContent = lines;
    const isOver = lines > 200;
    messaggioCount.classList.toggle('text-error', isOver);
    messaggioCount.classList.toggle('font-semibold', isOver);
  });

  function setLoading(loading) {
    submitBtn.disabled = loading;
    submitLabel.textContent = loading ? 'Invio in corso…' : 'Invia segnalazione';
    if (loading) {
      submitBtn.classList.add('loading', 'loading-spinner');
    } else {
      submitBtn.classList.remove('loading', 'loading-spinner');
    }
  }

  function showError(msg) {
    errorMsg.textContent = msg;
    errorBox.classList.remove('hidden');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    errorBox.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'center' });
  }

  function hideError() {
    errorBox.classList.add('hidden');
  }

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    hideError();
    clearFieldErrors();

    const fd = new FormData(form);
    const nome = String(fd.get('nome') || '').trim();
    const messaggio = String(fd.get('messaggio') || '').trim();
    const privacyAccettata = privacyCheck.checked;

    if (nome.length < 2) {
      showError('Il nome deve contenere almeno 2 caratteri.');
      setFieldError('nome', 'Il nome deve contenere almeno 2 caratteri.');
      return;
    }
    if (!emailInput.checkValidity()) {
      showError('Inserisci un indirizzo email valido.');
      setFieldError('email', 'Inserisci un indirizzo email valido.');
      return;
    }
    const righe = messaggio === '' ? 0 : messaggio.split('\n').length;
    if (righe > 200) {
      showError(`Il messaggio non può superare le 200 righe (attualmente ${righe}).`);
      setFieldError('messaggio', `Il messaggio non può superare le 200 righe (attualmente ${righe}).`);
      return;
    }
    if (!privacyAccettata) {
      showError('Devi accettare la Privacy Policy per inviare il modulo.');
      setFieldError('privacy', 'Devi accettare la Privacy Policy per inviare la segnalazione.');
      return;
    }
    if (!fd.get('altcha')) {
      showError('Completa la verifica antispam prima di inviare.');
      return;
    }

    setLoading(true);

    let data;
    try {
      const res = await fetch('/api/modulo_contatti', { method: 'POST', body: fd });
      data = await res.json();
    } catch (err) {
      setLoading(false);
      showError('Errore di rete. Controlla la connessione e riprova.');
      return;
    }

    setLoading(false);

    if (data.ok) {
      form.reset();
      modal.close();
      modalOk.showModal();
    } else {
      const messaggi = {
        campi_mancanti: 'Compila tutti i campi richiesti.',
        nome_troppo_corto: 'Il nome deve contenere almeno 2 caratteri.',
        email_non_valida: 'Inserisci un indirizzo email valido.',
        messaggio_troppo_lungo: 'Il messaggio non può superare le 200 righe.',
        verifica_fallita: 'Verifica antispam non valida. Ricarica la pagina e riprova.',
        privacy_non_accettata: 'Devi accettare la Privacy Policy per inviare la segnalazione.',
        invio_fallito: "Si è verificato un errore durante l'invio. Riprova più tardi.",
      };
      const msg = messaggi[data.error] ?? "Si è verificato un errore. Riprova più tardi.";
      showError(msg);
    }
  });
})();
</script>
