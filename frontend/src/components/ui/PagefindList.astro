---
import Icon from '../base/Icon.astro';

interface Props {
  type?: string;
  presetFilter?: Record<string, string>;
  filterKeys?: string[];
  filterLabels?: Record<string, string>;
  pageSize?: number;
  sortOptions?: Array<{ field: string; label: string; dir: string }>;
  initialQuery?: string;
}

const {
  type = '',
  presetFilter = {},
  filterKeys = [],
  filterLabels = {},
  pageSize = 15,
  sortOptions = [],
  initialQuery = '',
} = Astro.props;

const defaultLabels: Record<string, string> = {
  type: 'Tipo',
  periodi: 'Periodo storico',
  tags: 'Tag',
  lingue: 'Lingua',
  localizzazioni: 'Localizzazione',
  accordi: 'Accordi',
  audio: 'Audio',
};

const mergedLabels = { ...defaultLabels, ...filterLabels };
---

<pagefind-list
  data-type={type}
  data-preset-filter={JSON.stringify(presetFilter)}
  data-page-size={String(pageSize)}
  data-filter-keys={filterKeys.join(',')}
  data-filter-labels={JSON.stringify(mergedLabels)}
  data-sort-options={JSON.stringify(sortOptions)}
  data-initial-query={initialQuery}
  class="block"
>
  <!-- Desktop: contatore + filtri -->
  <div class="hidden sm:block mb-5">
    <div class="flex items-baseline gap-4 mb-4">
      <p data-result-count class="text-lg font-serif font-semibold text-base-content whitespace-nowrap"></p>
      <button type="button" data-reset-filters class="text-sm text-primary hover:text-primary/70 transition-colors hidden whitespace-nowrap">
        Rimuovi filtri
      </button>
    </div>
    <div class="flex items-center gap-4 flex-wrap">
      <div class="flex items-center gap-3">
        <Icon name="funnel" class="text-base-content/50 text-lg shrink-0" />
        <div data-filter-panel class="flex flex-wrap gap-2">
          <p class="text-base text-base-content/70 italic">Caricamento filtri…</p>
        </div>
      </div>
      <div data-sort-panel-desktop class="pl-4"></div>
    </div>
  </div>

  <!-- Mobile: contatore + bottone filtri -->
  <div class="sm:hidden mb-4">
    <div class="flex items-baseline gap-3 mb-3">
      <p data-result-count class="text-base font-serif font-semibold text-base-content"></p>
      <button type="button" data-reset-filters class="text-sm text-primary hover:text-primary/70 transition-colors hidden whitespace-nowrap">
        Rimuovi filtri
      </button>
    </div>
    <button type="button" data-filter-toggle class="btn btn-ghost btn-sm gap-2 border border-base-300">
      <Icon name="funnel" />
      Filtra l'elenco
      <span data-filter-count class="badge badge-secondary badge-sm hidden"></span>
    </button>
  </div>

  <!-- Drawer filtri (mobile) -->
  <dialog
    data-filter-drawer
    aria-label="Filtri"
    class="sm:hidden m-0 p-0 max-w-none max-h-none w-full h-full bg-transparent"
  >
    <div class="absolute inset-y-0 left-0 w-72 max-w-full bg-base-100 shadow-xl flex flex-col">
      <div class="flex items-center justify-between p-4 border-b border-base-300">
        <h2 class="font-serif font-bold text-base">Filtra l'elenco</h2>
        <button
          type="button"
          data-drawer-close
          class="btn btn-ghost btn-sm btn-circle"
          aria-label="Chiudi"
        ><Icon name="x" /></button>
      </div>
      <div data-filter-panel-mobile class="flex-1 overflow-y-auto p-4">
        <p class="text-sm text-base-content/70 italic">Caricamento filtri…</p>
      </div>
      <div class="p-4 border-t border-base-300 flex gap-2">
        <button type="button" data-reset-filters class="btn btn-ghost btn-sm flex-1">Rimuovi filtri</button>
        <button type="button" data-drawer-close class="btn btn-primary btn-sm flex-1">Applica</button>
      </div>
    </div>
  </dialog>

  <!-- Filtri attivi (badges) -->
  <div data-active-filters class="hidden flex-wrap gap-2 mb-5"></div>

  <span data-result-count-live role="status" class="sr-only"></span>

  <h2 class="sr-only">Risultati</h2>

  <!-- Lista risultati -->
  <ul data-results role="list" class="max-w-2xl mx-auto flex flex-col divide-y divide-secondary/30">
    <li class="py-12 flex justify-center">
      <span class="loading loading-spinner loading-md text-primary"></span>
    </li>
  </ul>

  <!-- Paginazione -->
  <nav data-pagination aria-label="Paginazione" class="flex justify-center flex-wrap gap-2 mt-8"></nav>
</pagefind-list>

<script is:inline>
  // is:inline obbligatorio: dipende da /pagefind/pagefind.js generato a build-time,
  // non risolvibile da Vite/Rollup (stessa ragione di search-modal in Header.astro).
  (function () {
    const _svg = (d) => `<span aria-hidden="true" class="inline-flex items-center justify-center shrink-0 [&>svg]:w-[1em] [&>svg]:h-[1em]"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">${d}</svg></span>`;
    const ICO = {
      headphones: (cls) => `<span class="${cls}">${_svg('<path d="M201.89,54.66A103.43,103.43,0,0,0,128.79,24H128A104,104,0,0,0,24,128v56a24,24,0,0,0,24,24H64a24,24,0,0,0,24-24V144a24,24,0,0,0-24-24H40.36A88,88,0,0,1,128,40h.67a87.71,87.71,0,0,1,87,80H192a24,24,0,0,0-24,24v40a24,24,0,0,0,24,24h16a24,24,0,0,0,24-24V128A103.41,103.41,0,0,0,201.89,54.66ZM64,136a8,8,0,0,1,8,8v40a8,8,0,0,1-8,8H48a8,8,0,0,1-8-8V136Zm152,48a8,8,0,0,1-8,8H192a8,8,0,0,1-8-8V144a8,8,0,0,1,8-8h24Z"/>')}</span>`,
      guitar: (cls) => `<span class="${cls}">${_svg('<path d="M249.66,46.34l-40-40a8,8,0,0,0-11.31,11.32L200.69,20,140.52,80.16C117.73,68.3,92.21,69.29,76.75,84.74a42.27,42.27,0,0,0-9.39,14.37A8.24,8.24,0,0,1,59.81,104c-14.59.49-27.26,5.72-36.65,15.11C11.08,131.22,6,148.6,8.74,168.07,11.4,186.7,21.07,205.15,36,220s33.34,24.56,52,27.22A71.13,71.13,0,0,0,98.1,248c15.32,0,28.83-5.23,38.76-15.16,9.39-9.39,14.62-22.06,15.11-36.65a8.24,8.24,0,0,1,4.92-7.55,42.12,42.12,0,0,0,14.37-9.39c15.45-15.46,16.44-41,4.58-63.77L236,55.31l2.34,2.34a8,8,0,1,0,11.32-11.31ZM160,167.93a26.12,26.12,0,0,1-8.95,5.83,24.24,24.24,0,0,0-15,21.89c-.36,10.46-4,19.41-10.43,25.88-8.44,8.43-21,11.95-35.36,9.89C75,229.25,59.73,221.19,47.27,208.73S26.75,181,24.58,165.81c-2-14.37,1.46-26.92,9.89-35.36C40.94,124,49.89,120.37,60.35,120h0a24.22,24.22,0,0,0,21.89-15,26.12,26.12,0,0,1,5.83-9c5.49-5.49,13-8.13,21.38-8.13a49.38,49.38,0,0,1,19.13,4.19L108.5,112.19a32,32,0,1,0,35.31,35.31l20.08-20.08C170.41,142.71,169.47,158.41,160,167.93Zm-10.4-61.48a72.9,72.9,0,0,1,5.93,6.75l-15.42,15.42a32.22,32.22,0,0,0-12.68-12.68l15.42-15.43A73,73,0,0,1,149.55,106.45ZM112,128a16,16,0,0,1,16,16h0a16,16,0,1,1-16-16Zm48.85-32.85a86.94,86.94,0,0,0-6.68-6L176,67.31,188.69,80l-21.83,21.82A86.94,86.94,0,0,0,160.86,95.14ZM200,68.68,187.32,56,212,31.31,224.69,44ZM93.66,194.33a8,8,0,0,1-11.31,11.32l-32-32a8,8,0,0,1,11.32-11.31Z"/>')}</span>`,
      user: (cls) => `<span class="${cls}">${_svg('<path d="M230.92,212c-15.23-26.33-38.7-45.21-66.09-54.16a72,72,0,1,0-73.66,0C63.78,166.78,40.31,185.66,25.08,212a8,8,0,1,0,13.85,8c18.84-32.56,52.14-52,89.07-52s70.23,19.44,89.07,52a8,8,0,1,0,13.85-8ZM72,96a56,56,0,1,1,56,56A56.06,56.06,0,0,1,72,96Z"/>')}</span>`,
      caretDown: _svg('<path d="M213.66,101.66l-80,80a8,8,0,0,1-11.32,0l-80-80A8,8,0,0,1,53.66,90.34L128,164.69l74.34-74.35a8,8,0,0,1,11.32,11.32Z"/>'),
      x: _svg('<path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"/>'),
      check: _svg('<path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/>'),
      sortAsc: _svg('<path d="M128,128a8,8,0,0,1-8,8H48a8,8,0,0,1,0-16h72A8,8,0,0,1,128,128ZM48,72H184a8,8,0,0,0,0-16H48a8,8,0,0,0,0,16Zm56,112H48a8,8,0,0,0,0,16h56a8,8,0,0,0,0-16Zm125.66-21.66a8,8,0,0,0-11.32,0L192,188.69V112a8,8,0,0,0-16,0v76.69l-26.34-26.35a8,8,0,0,0-11.32,11.32l40,40a8,8,0,0,0,11.32,0l40-40A8,8,0,0,0,229.66,162.34Z"/>'),
    };
    const _esc = (s) => { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };
    const VIEW_MORE_THRESHOLD = 10;

    const DEFAULT_LABELS = {
      type: 'Tipo',
      periodi: 'Periodo storico',
      tags: 'Tag',
      lingue: 'Lingua',
      localizzazioni: 'Localizzazione',
      accordi: 'Accordi',
      audio: 'Audio',
    };

    class PagefindList extends HTMLElement {
      connectedCallback() {
        this._pf          = null;
        this._allFilters  = {};
        this._results     = [];
        this._page        = 0;
        this._filters     = {};
        this._query       = '';
        this._pageSize    = parseInt(this.dataset.pageSize   || '15', 10);
        this._type        = this.dataset.type                || '';
        this._filterKeys  = (this.dataset.filterKeys || '').split(',').filter(Boolean);
        this._filterLabels = { ...DEFAULT_LABELS, ...JSON.parse(this.dataset.filterLabels || '{}') };
        this._sortOptions = JSON.parse(this.dataset.sortOptions || '[]');
        this._sortField   = this._sortOptions[0]?.field ?? 'titolo';
        this._sortDir     = this._sortOptions[0]?.dir   ?? 'asc';

        this._presetFilter = JSON.parse(this.dataset.presetFilter || '{}');

        // Espone setQuery() per chiamate esterne (es. pagina cerca)
        this.setQuery = async (q) => {
          this._query = q;
          this._page  = 0;
          await this._search();
        };

        this._setupDrawer();
        this._init();
      }

      // ── Init ────────────────────────────────────────────────────────────────

      async _init() {
        try {
          this._pf = await import('/pagefind/pagefind.js');
          await this._pf.init();
          // Leggi la query iniziale DOPO l'import asincrono: gli script della
          // pagina (es. cerca.astro) hanno già avuto modo di impostare il dataset.
          this._query = this.dataset.initialQuery || '';
          await this._pf.filters(); // preload filter data into memory
          const baseFilters = { ...(this._type ? { type: this._type } : {}), ...this._presetFilter };
          const preSearch = await this._pf.search(this._query || null, { filters: baseFilters });
          const rawFilters = preSearch.filters ?? {};
          // Remove always-active preset keys from user-selectable facets
          for (const key of Object.keys(this._presetFilter)) {
            delete rawFilters[key];
          }
          this._allFilters = rawFilters;
          this._renderFilterPanels();
          this._renderSortControls();
          await this._search();
        } catch (e) {
          console.error('[pagefind-list]', e);
          this._showError();
        }
      }

      // ── Search ──────────────────────────────────────────────────────────────

      async _search() {
        const baseFilters = { ...(this._type ? { type: this._type } : {}), ...this._presetFilter };
        const opts = { filters: { ...baseFilters, ...this._filters } };
        if (!this._query) opts.sort = { [this._sortField]: this._sortDir };
        const search = await this._pf.search(this._query || null, opts);
        this._results = search.results;
        this._page    = 0;
        await this._renderPage();
        this._renderActiveFilters();
        this._updateResultCount();
      }

      // ── Results ─────────────────────────────────────────────────────────────

      async _renderPage() {
        const start = this._page * this._pageSize;
        const items = await Promise.all(
          this._results.slice(start, start + this._pageSize).map((r) => r.data())
        );
        const el = this.querySelector('[data-results]');
        el.innerHTML = items.length === 0
          ? '<li class="py-12 text-center font-serif italic text-lg text-base-content/70">Nessun risultato.</li>'
          : items.map((item) => `<li>${this._renderCard(item)}</li>`).join('');
        this._renderPagination();
      }

      _renderCard(item) {
        const meta = item.meta || {};
        item.url = item.url.replace(/\/$/, '') || '/';
        const cardType = this._type || (meta.type ?? '');
        const e = _esc;

        if (cardType === 'periodi') {
          return `
            <div class="flex flex-col gap-1.5 py-4 hover:bg-base-200 transition-colors rounded-lg px-2">
              <h3 class="font-serif font-semibold text-lg text-primary">
                <a href="${e(item.url)}" class="hover:underline">${e(meta.title)}</a>
              </h3>
              <p class="text-sm text-base-content/70 uppercase tracking-wide font-sans">Periodo storico</p>
            </div>
          `;
        }

        if (cardType === 'traduzioni') {
          const cantoLink = meta.canto_originale_titolo
            ? (meta.canto_originale_slug
                ? `<a href="/canti/${e(meta.canto_originale_slug)}" class="hover:underline">${e(meta.canto_originale_titolo)}</a>`
                : e(meta.canto_originale_titolo))
            : '';
          return `
            <div class="flex flex-col gap-1.5 py-4 hover:bg-base-200 transition-colors rounded-lg px-2">
              <h3 class="font-serif font-semibold text-lg text-primary">
                <a href="${e(item.url)}" class="hover:underline">${e(meta.title)}</a>
              </h3>
              ${cantoLink ? `<p class="font-serif italic text-base text-base-content/70">Canto originale: ${cantoLink}</p>` : ''}
            </div>
          `;
        }

        if (cardType === 'autori') {
          const numCanti = meta.num_canti ? parseInt(meta.num_canti, 10) : 0;
          const foto = meta.image
            ? `<img src="${e(meta.image)}" alt="Foto di ${e(meta.title)}" width="64" height="64" loading="lazy" class="w-16 h-16 rounded-full object-cover border-2 border-base-300 grayscale group-hover:grayscale-0 transition-all duration-300" />`
            : `<div class="w-16 h-16 rounded-full bg-base-200 flex items-center justify-center border-2 border-base-300">${ICO.user('text-base-content/50 text-3xl')}</div>`;
          return `
            <div class="flex items-center gap-4 py-4 hover:bg-base-200 transition-colors rounded-lg px-2 group">
              <div class="shrink-0">${foto}</div>
              <div class="flex flex-col gap-1.5 min-w-0">
                <h3 class="font-serif font-semibold text-lg text-primary">
                  <a href="${e(item.url)}" class="hover:underline">${e(meta.title)}</a>
                </h3>
                ${meta.localizzazioni ? `<p class="font-serif italic text-base text-base-content/70">${e(meta.localizzazioni)}</p>` : ''}
                ${numCanti > 0 ? `<p class="text-sm text-base-content/70">${numCanti} ${numCanti === 1 ? 'canto' : 'canti'}</p>` : ''}
              </div>
            </div>
          `;
        }

        if (cardType === 'eventi') {
          const loc     = meta.localizzazioni ?? '';
          const locSlug = meta.localizzazioni_slug ?? '';
          const locHtml = loc
            ? (locSlug ? `<a href="/localizzazioni/${e(locSlug)}" class="hover:underline">${e(loc)}</a>` : e(loc))
            : '';
          const periodoHtml = meta.periodi
            ? (meta.periodi_slug
                ? `<a href="/periodi/${e(meta.periodi_slug)}" class="hover:underline">${e(meta.periodi)}</a>`
                : e(meta.periodi))
            : '';
          const dateStr    = e(meta.data_display ?? '');
          const metaLine1  = [locHtml, dateStr].filter(Boolean).join(' &middot; ');
          return `
            <div class="flex flex-col gap-1.5 py-4 hover:bg-base-200 transition-colors rounded-lg px-2">
              <h3 class="font-serif font-semibold text-lg text-primary">
                <a href="${e(item.url)}" class="hover:underline">${e(meta.title)}</a>
              </h3>
              ${metaLine1   ? `<p class="font-serif italic text-base text-base-content/70">${metaLine1}</p>`   : ''}
              ${periodoHtml ? `<p class="font-serif italic text-base text-base-content/70">${periodoHtml}</p>` : ''}
            </div>
          `;
        }

        if (cardType === 'pagine') {
          return `
            <div class="flex flex-col gap-1.5 py-4 hover:bg-base-200 transition-colors rounded-lg px-2">
              <h3 class="font-serif font-semibold text-lg text-primary">
                <a href="${e(item.url)}" class="hover:underline">${e(meta.title)}</a>
              </h3>
              <p class="text-sm text-base-content/70 uppercase tracking-wide font-sans">Pagina</p>
            </div>
          `;
        }

        if (cardType === 'tags') {
          return `
            <div class="flex flex-col gap-1.5 py-4 hover:bg-base-200 transition-colors rounded-lg px-2">
              <h3 class="font-serif font-semibold text-lg text-primary">
                <a href="${e(item.url)}" class="hover:underline">${e(meta.title)}</a>
              </h3>
              <p class="text-sm text-base-content/70 uppercase tracking-wide font-sans">Tag</p>
            </div>
          `;
        }

        const accordi = meta.accordi === 'sì';
        const audio   = meta.audio   === 'sì';
        return `
          <div class="flex flex-col gap-1.5 py-4 hover:bg-base-200 transition-colors rounded-lg px-2">
            <p class="text-sm text-base-content/70 flex items-center gap-2">
              ${meta.anno ? `<span class="italic">${e(meta.anno)}</span><span aria-hidden="true">&middot;</span>` : ''}
              ${ICO.headphones(audio ? 'text-primary' : 'text-base-content/40')}${audio ? '<span class="sr-only">Audio disponibile</span>' : ''}
              ${ICO.guitar(accordi ? 'text-primary' : 'text-base-content/40')}${accordi ? '<span class="sr-only">Accordi disponibili</span>' : ''}
            </p>
            <h3 class="font-serif font-semibold text-lg text-primary">
              <a href="${e(item.url)}" class="hover:underline">${e(meta.title)}</a>
            </h3>
            ${meta.autori    ? `<p class="text-base text-base-content/70">${e(meta.autori)}</p>`    : ''}
            ${meta.capoverso ? `<p class="italic text-base text-base-content/70">${e(meta.capoverso)}</p>` : ''}
          </div>
        `;
      }

      // ── Pagination ──────────────────────────────────────────────────────────

      _renderPagination() {
        const el    = this.querySelector('[data-pagination]');
        const total = Math.ceil(this._results.length / this._pageSize);
        if (!el || total <= 1) { if (el) el.innerHTML = ''; return; }

        const cur   = this._page;
        const parts = [];
        const btn   = (n) => {
          const active = n === cur;
          return `<button type="button" data-page="${n}" aria-label="Pagina ${n + 1}"${active ? ' aria-current="page"' : ''} class="btn btn-sm ${active ? 'btn-primary' : 'btn-ghost !border-transparent'}">${n + 1}</button>`;
        };
        const dots  = () => '<span class="px-2 self-center text-base-content/50">…</span>';

        parts.push(btn(0));
        if (cur > 2) parts.push(dots());
        for (let i = Math.max(1, cur - 1); i <= Math.min(total - 2, cur + 1); i++) parts.push(btn(i));
        if (cur < total - 3) parts.push(dots());
        if (total > 1) parts.push(btn(total - 1));

        el.innerHTML = parts.join('');
        el.querySelectorAll('[data-page]').forEach((b) =>
          b.addEventListener('click', async () => {
            this._page = parseInt(b.dataset.page, 10);
            await this._renderPage();
            const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            this.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
          })
        );
      }

      // ── Filter panels ────────────────────────────────────────────────────────

      _renderFilterPanels() {
        const keys = this._filterKeys.filter(
          (k) => this._allFilters[k] && Object.keys(this._allFilters[k]).length > 0
        );

        // Desktop: dropdown button per ogni gruppo
        const desktopPanel = this.querySelector('[data-filter-panel]');
        if (desktopPanel) {
          desktopPanel.innerHTML = keys.length > 0
            ? keys.map((k) => this._dropdownButtonHtml(k)).join('')
            : '<p class="text-sm text-base-content/70 italic">Nessun filtro disponibile.</p>';
          this._setupDropdowns();
        }

        // Mobile: gruppi verticali con checkbox (nel drawer)
        const mobilePanel = this.querySelector('[data-filter-panel-mobile]');
        if (mobilePanel) {
          mobilePanel.innerHTML = keys.length > 0
            ? `<div class="flex flex-col gap-5">${keys.map((k) => this._checkboxGroupHtml(k)).join('')}</div>`
            : '<p class="text-sm text-base-content/70 italic">Nessun filtro disponibile.</p>';
        }

        this._attachFilterEvents();
      }

      // HTML di un singolo dropdown button con il suo pannello flottante
      _dropdownButtonHtml(key) {
        const label   = this._filterLabels[key] ?? key;
        const entries = Object.entries(this._allFilters[key])
          .filter(([, count]) => count > 0)
          .sort(([, a], [, b]) => b - a);
        const visible = entries.slice(0, VIEW_MORE_THRESHOLD);
        const extra   = entries.slice(VIEW_MORE_THRESHOLD);

        const itemHtml = ([val, count]) => `
          <label class="flex items-center gap-2 px-3 py-2 cursor-pointer hover:bg-base-200 text-base">
            <input
              type="checkbox"
              class="checkbox checkbox-sm checkbox-primary"
              data-filter-key="${key}"
              data-filter-val="${val}"
            />
            <span class="flex-1">${val}</span>
            <span class="text-sm text-base-content/70">${count}</span>
          </label>
        `;

        return `
          <div class="relative" data-dropdown-group="${key}">
            <button
              type="button"
              data-dropdown-toggle="${key}"
              aria-expanded="false"
              aria-controls="pf-dropdown-${key}"
              class="btn btn-md btn-ghost border border-base-300 gap-1"
            >
              ${label}
              <span class="text-xs">${ICO.caretDown}</span>
            </button>
            <div
              id="pf-dropdown-${key}"
              data-dropdown-panel="${key}"
              class="hidden absolute left-0 top-[calc(100%+4px)] z-50
                     bg-base-100 border border-base-300 rounded-box shadow-lg
                     min-w-48 max-h-72 overflow-y-auto py-1"
            >
              ${visible.map(itemHtml).join('')}
              ${extra.length > 0 ? `
                <div data-extra-items="${key}" class="hidden">
                  ${extra.map(itemHtml).join('')}
                </div>
                <button
                  type="button"
                  data-show-more="${key}"
                  class="w-full text-left px-3 py-1.5 text-xs text-primary hover:underline"
                >
                  + ${extra.length} altri…
                </button>
              ` : ''}
            </div>
          </div>
        `;
      }

      // HTML di un gruppo con label + checkbox (usato nel drawer mobile)
      _checkboxGroupHtml(key) {
        const label   = this._filterLabels[key] ?? key;
        const entries = Object.entries(this._allFilters[key])
          .filter(([, count]) => count > 0)
          .sort(([, a], [, b]) => b - a);
        const visible = entries.slice(0, VIEW_MORE_THRESHOLD);
        const extra   = entries.slice(VIEW_MORE_THRESHOLD);

        const itemHtml = ([val, count]) => `
          <li>
            <label class="flex items-center gap-2 cursor-pointer py-1.5 text-base group">
              <input
                type="checkbox"
                class="checkbox checkbox-sm checkbox-primary"
                data-filter-key="${key}"
                data-filter-val="${val}"
              />
              <span class="flex-1 group-hover:text-primary transition-colors">${val}</span>
              <span class="text-sm text-base-content/70">${count}</span>
            </label>
          </li>
        `;

        return `
          <div class="flex flex-col gap-1.5">
            <h3 class="font-serif font-bold text-sm uppercase tracking-wide text-base-content/70">${label}</h3>
            <ul class="flex flex-col gap-0">
              ${visible.map(itemHtml).join('')}
              ${extra.length > 0 ? `
                <ul data-extra-items="${key}" class="hidden flex flex-col gap-0">
                  ${extra.map(itemHtml).join('')}
                </ul>
                <button
                  type="button"
                  data-show-more="${key}"
                  class="text-left py-1 text-xs text-primary hover:underline"
                >
                  + ${extra.length} altri…
                </button>
              ` : ''}
            </ul>
          </div>
        `;
      }

      // ── Dropdown toggle (desktop) ────────────────────────────────────────────

      _setupDropdowns() {
        const panel = this.querySelector('[data-filter-panel]');
        if (!panel) return;

        // Apri/chiudi al click sul bottone
        panel.querySelectorAll('[data-dropdown-toggle]').forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const key      = btn.dataset.dropdownToggle;
            const dropPanel = panel.querySelector(`[data-dropdown-panel="${key}"]`);
            const isOpen   = !dropPanel.classList.contains('hidden');
            this._closeAllDropdowns();
            if (!isOpen) {
              dropPanel.classList.remove('hidden');
              btn.setAttribute('aria-expanded', 'true');
            }
          });
        });

        // "Mostra altri" — espande gli item nascosti nel pannello flottante
        panel.querySelectorAll('[data-show-more]').forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const key   = btn.dataset.showMore;
            const extra = panel.querySelector(`[data-dropdown-panel="${key}"] [data-extra-items="${key}"]`);
            if (extra) extra.classList.remove('hidden');
            btn.remove();
          });
        });

        // Chiudi cliccando fuori
        document.addEventListener('click', (e) => {
          if (!this.contains(e.target)) this._closeAllDropdowns();
        });

        // Chiudi con Escape
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') this._closeAllDropdowns();
        });
      }

      _closeAllDropdowns() {
        this.querySelectorAll('[data-dropdown-panel]').forEach((p) => p.classList.add('hidden'));
        this.querySelectorAll('[data-dropdown-toggle]').forEach((btn) => btn.setAttribute('aria-expanded', 'false'));
      }

      // Aggiorna label e stile dei bottoni dropdown in base ai filtri attivi
      _updateDropdownButtons() {}

      // ── Filter events ────────────────────────────────────────────────────────

      _attachFilterEvents() {
        this.querySelectorAll('[data-filter-key]').forEach((input) => {
          input.addEventListener('change', async () => {
            const { filterKey: key, filterVal: val } = input.dataset;

            if (input.checked) {
              // Single-select per gruppo: deseleziona il valore precedente
              this.querySelectorAll(`[data-filter-key="${key}"]`).forEach((cb) => {
                if (cb !== input) cb.checked = false;
              });
              this._filters[key] = val;
            } else {
              delete this._filters[key];
            }

            // Chiudi il dropdown dopo la selezione
            this._closeAllDropdowns();

            await this._search();
          });
        });

        // "Mostra altri" nel drawer mobile
        this.querySelector('[data-filter-panel-mobile]')
          ?.querySelectorAll('[data-show-more]')
          .forEach((btn) => {
            btn.addEventListener('click', () => {
              const extra = btn.previousElementSibling;
              if (extra) extra.classList.remove('hidden');
              btn.remove();
            });
          });

        // Reset
        this.querySelectorAll('[data-reset-filters]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            this._filters = {};
            this.querySelectorAll('[data-filter-key]').forEach((cb) => { cb.checked = false; });
            await this._search();
          });
        });
      }

      // ── Active filters (badges) ──────────────────────────────────────────────

      _renderActiveFilters() {
        const el      = this.querySelector('[data-active-filters]');
        if (!el) return;
        const entries = Object.entries(this._filters);

        el.classList.toggle('hidden', entries.length === 0);
        el.classList.toggle('flex',   entries.length > 0);

        el.innerHTML = entries.map(([key, val]) => `
          <button
            type="button"
            data-remove-filter="${_esc(key)}"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm bg-secondary/15 text-base-content rounded-full cursor-pointer hover:bg-secondary/25 transition-colors"
            aria-label="Rimuovi filtro ${_esc(val)}"
          >
            ${_esc(val)} <span class="text-xs leading-none">${ICO.x}</span>
          </button>
        `).join('');

        el.querySelectorAll('[data-remove-filter]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const key = btn.dataset.removeFilter;
            delete this._filters[key];
            this.querySelectorAll(`[data-filter-key="${key}"]`).forEach((cb) => { cb.checked = false; });
            await this._search();
          });
        });

        // Badge count sul bottone mobile
        const countBadge = this.querySelector('[data-filter-count]');
        if (countBadge) {
          countBadge.textContent = String(entries.length);
          countBadge.classList.toggle('hidden', entries.length === 0);
        }

        // Bottoni reset (desktop + mobile)
        this.querySelectorAll('[data-reset-filters]').forEach((btn) => {
          btn.classList.toggle('hidden', entries.length === 0);
        });

        // Aggiorna label bottoni dropdown
        this._updateDropdownButtons();
      }

      _updateResultCount() {
        const n    = this._results.length;
        const text = n === 0 ? 'Nessun risultato' : `${n} risultat${n === 1 ? 'o' : 'i'}`;
        this.querySelectorAll('[data-result-count]').forEach((el) => { el.textContent = text; });
        const live = this.querySelector('[data-result-count-live]');
        if (live) live.textContent = text;
      }

      // ── Drawer (mobile) ──────────────────────────────────────────────────────

      _setupDrawer() {
        const toggle = this.querySelector('[data-filter-toggle]');
        const drawer = this.querySelector('[data-filter-drawer]');
        if (!toggle || !drawer) return;

        const open  = () => { drawer.showModal(); document.body.style.overflow = 'hidden'; };
        const close = () => { if (drawer.open) drawer.close(); };

        toggle.addEventListener('click', open);
        drawer.querySelectorAll('[data-drawer-close]').forEach((b) => b.addEventListener('click', close));

        // Click sull'area trasparente del dialog (fuori dal pannello) lo chiude
        drawer.addEventListener('click', (e) => { if (e.target === drawer) close(); });

        // Copre sia Esc (evento 'cancel' nativo) sia close() esplicita
        drawer.addEventListener('close', () => { document.body.style.overflow = ''; });
      }

      // ── Sort controls ────────────────────────────────────────────────────────

      _renderSortControls() {
        if (this._sortOptions.length === 0) return;

        // Desktop: dropdown button
        const desktopContainer = this.querySelector('[data-sort-panel-desktop]');
        if (desktopContainer) {
          const _isActiveSort = (o) => o.field === this._sortField && o.dir === this._sortDir;
          const activeLabel = this._sortOptions.find(_isActiveSort)?.label ?? 'Ordina';
          desktopContainer.innerHTML = `
            <div class="flex items-center gap-3" data-sort-dropdown>
              <span class="text-base-content/50 text-lg shrink-0">${ICO.sortAsc}</span>
              <div class="relative">
                <button type="button" data-sort-toggle aria-expanded="false" aria-controls="pf-sort-dropdown-panel" class="btn btn-md btn-ghost border border-base-300 gap-1">
                  ${activeLabel} <span class="text-xs">${ICO.caretDown}</span>
                </button>
                <div id="pf-sort-dropdown-panel" data-sort-dropdown-panel class="hidden absolute right-0 top-[calc(100%+4px)] z-50
                     bg-base-100 border border-base-300 rounded-box shadow-lg min-w-40 py-1">
                  ${this._sortOptions.map((o) => `
                    <button type="button" data-sort-select="${o.field}" data-sort-dir="${o.dir}"
                      class="flex items-center gap-2 w-full px-3 py-1.5 text-sm hover:bg-base-200 text-left
                             ${_isActiveSort(o) ? 'text-primary font-semibold' : ''}">
                      <span class="text-xs ${_isActiveSort(o) ? '' : 'invisible'}">${ICO.check}</span>
                      ${o.label}
                    </button>
                  `).join('')}
                </div>
              </div>
            </div>
          `;

          const dropdown = desktopContainer.querySelector('[data-sort-dropdown]');
          const toggle   = dropdown.querySelector('[data-sort-toggle]');
          const panel    = dropdown.querySelector('[data-sort-dropdown-panel]');

          toggle.addEventListener('click', (e) => {
            e.stopPropagation();
            const willOpen = panel.classList.contains('hidden');
            panel.classList.toggle('hidden');
            toggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          });

          dropdown.querySelectorAll('[data-sort-select]').forEach((btn) => {
            btn.addEventListener('click', async () => {
              this._sortField = btn.dataset.sortSelect;
              this._sortDir   = btn.dataset.sortDir;
              panel.classList.add('hidden');
              toggle.setAttribute('aria-expanded', 'false');
              this._updateSortUI();
              await this._search();
            });
          });

          document.addEventListener('click', (e) => {
            if (!dropdown.contains(e.target)) {
              panel.classList.add('hidden');
              toggle.setAttribute('aria-expanded', 'false');
            }
          });
        }

        // Mobile: prepend sort section to the filter drawer
        const mobilePanel = this.querySelector('[data-filter-panel-mobile]');
        if (mobilePanel && !mobilePanel.querySelector('[data-sort-section-mobile]')) {
          mobilePanel.insertAdjacentHTML('afterbegin', `
            <div data-sort-section-mobile class="flex flex-col gap-1.5 pb-5 mb-5 border-b border-base-300">
              <h3 class="font-serif font-bold text-xs uppercase tracking-wide text-base-content/70">Ordina</h3>
              <div class="flex flex-col gap-0">
                ${this._sortOptions.map((o) => `
                  <label class="flex items-center gap-2 cursor-pointer py-1 text-sm group">
                    <input type="radio" name="sort-mobile" class="radio radio-xs radio-primary"
                      data-sort-select="${o.field}" data-sort-dir="${o.dir}"
                      ${o.field === this._sortField && o.dir === this._sortDir ? 'checked' : ''} />
                    <span class="flex-1 group-hover:text-primary transition-colors">${o.label}</span>
                  </label>
                `).join('')}
              </div>
            </div>
          `);

          mobilePanel.querySelectorAll('[data-sort-select]').forEach((input) => {
            input.addEventListener('change', async () => {
              this._sortField = input.dataset.sortSelect;
              this._sortDir   = input.dataset.sortDir;
              this._updateSortUI();
              await this._search();
            });
          });
        }
      }

      _updateSortUI() {
        const _isActive = (el) => el.dataset.sortSelect === this._sortField && el.dataset.sortDir === this._sortDir;
        // Update desktop button label
        const toggle = this.querySelector('[data-sort-toggle]');
        if (toggle) {
          const activeLabel = this._sortOptions.find((o) => o.field === this._sortField && o.dir === this._sortDir)?.label ?? 'Ordina';
          toggle.innerHTML = `${activeLabel} <span class="text-xs">${ICO.caretDown}</span>`;
        }
        // Update desktop check marks + active styles
        this.querySelector('[data-sort-dropdown-panel]')?.querySelectorAll('[data-sort-select]').forEach((btn) => {
          const active = _isActive(btn);
          btn.classList.toggle('text-primary', active);
          btn.classList.toggle('font-semibold', active);
          const check = btn.querySelector('span');
          if (check) check.classList.toggle('invisible', !active);
        });
        // Sync mobile radio states
        this.querySelectorAll('[data-sort-section-mobile] [data-sort-select]').forEach((input) => {
          input.checked = _isActive(input);
        });
      }

      _showError() {
        const el = this.querySelector('[data-results]');
        if (el) el.innerHTML = '<li class="py-10 text-center text-base-content/70">Errore nel caricamento.</li>';
      }
    }

    if (!customElements.get('pagefind-list')) {
      customElements.define('pagefind-list', PagefindList);
    }
  })();
</script>
