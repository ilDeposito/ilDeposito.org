---
interface Props {
  autori?: string[];
  tags?: string[];
  periodo?: string | null;
  excludeUrl: string;
  pageSize?: number;
}

const {
  autori = [],
  tags = [],
  periodo = null,
  excludeUrl,
  pageSize = 4,
} = Astro.props;
---

<!--
  Nota: una singola query testuale (titolo+capoverso+tag+autori) NON funziona
  per un "more like this" con Pagefind, perché il motore combina i termini di
  ricerca in AND — una frase multi-parola quasi sempre matcha solo la pagina
  sorgente stessa. Si usano invece filtri espliciti (autori/periodi/tags, già
  indicizzati con data-pagefind-filter) combinati con un merge pesato lato client.
-->
<more-like-this
  data-autori={JSON.stringify(autori)}
  data-tags={JSON.stringify(tags)}
  data-periodo={periodo ?? ''}
  data-exclude-url={excludeUrl}
  data-page-size={String(pageSize)}
  class="hidden"
>
  <section class="flex flex-col gap-2 max-w-2xl mx-auto mt-6">
    <h2 class="font-serif font-bold text-base md:text-lg text-base-content">Canti simili</h2>
    <div data-mlt-results class="flex flex-col divide-y divide-secondary/30"></div>
  </section>
</more-like-this>

<script is:inline>
  // is:inline obbligatorio: dipende da /pagefind/pagefind.js generato a build-time,
  // non risolvibile da Vite/Rollup (stessa ragione di PagefindList.astro).
  (function () {
    const _svg = (d) => `<span class="inline-flex items-center justify-center shrink-0 [&>svg]:w-[1em] [&>svg]:h-[1em]"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">${d}</svg></span>`;
    const headphones = (cls) => `<span class="${cls}">${_svg('<path d="M201.89,54.66A103.43,103.43,0,0,0,128.79,24H128A104,104,0,0,0,24,128v56a24,24,0,0,0,24,24H64a24,24,0,0,0,24-24V144a24,24,0,0,0-24-24H40.36A88,88,0,0,1,128,40h.67a87.71,87.71,0,0,1,87,80H192a24,24,0,0,0-24,24v40a24,24,0,0,0,24,24h16a24,24,0,0,0,24-24V128A103.41,103.41,0,0,0,201.89,54.66ZM64,136a8,8,0,0,1,8,8v40a8,8,0,0,1-8,8H48a8,8,0,0,1-8-8V136Zm152,48a8,8,0,0,1-8,8H192a8,8,0,0,1-8-8V144a8,8,0,0,1,8-8h24Z"/>')}</span>`;
    const guitar = (cls) => `<span class="${cls}">${_svg('<path d="M249.66,46.34l-40-40a8,8,0,0,0-11.31,11.32L200.69,20,140.52,80.16C117.73,68.3,92.21,69.29,76.75,84.74a42.27,42.27,0,0,0-9.39,14.37A8.24,8.24,0,0,1,59.81,104c-14.59.49-27.26,5.72-36.65,15.11C11.08,131.22,6,148.6,8.74,168.07,11.4,186.7,21.07,205.15,36,220s33.34,24.56,52,27.22A71.13,71.13,0,0,0,98.1,248c15.32,0,28.83-5.23,38.76-15.16,9.39-9.39,14.62-22.06,15.11-36.65a8.24,8.24,0,0,1,4.92-7.55,42.12,42.12,0,0,0,14.37-9.39c15.45-15.46,16.44-41,4.58-63.77L236,55.31l2.34,2.34a8,8,0,1,0,11.32-11.31ZM160,167.93a26.12,26.12,0,0,1-8.95,5.83,24.24,24.24,0,0,0-15,21.89c-.36,10.46-4,19.41-10.43,25.88-8.44,8.43-21,11.95-35.36,9.89C75,229.25,59.73,221.19,47.27,208.73S26.75,181,24.58,165.81c-2-14.37,1.46-26.92,9.89-35.36C40.94,124,49.89,120.37,60.35,120h0a24.22,24.22,0,0,0,21.89-15,26.12,26.12,0,0,1,5.83-9c5.49-5.49,13-8.13,21.38-8.13a49.38,49.38,0,0,1,19.13,4.19L108.5,112.19a32,32,0,1,0,35.31,35.31l20.08-20.08C170.41,142.71,169.47,158.41,160,167.93Zm-10.4-61.48a72.9,72.9,0,0,1,5.93,6.75l-15.42,15.42a32.22,32.22,0,0,0-12.68-12.68l15.42-15.43A73,73,0,0,1,149.55,106.45ZM112,128a16,16,0,0,1,16,16h0a16,16,0,1,1-16-16Zm48.85-32.85a86.94,86.94,0,0,0-6.68-6L176,67.31,188.69,80l-21.83,21.82A86.94,86.94,0,0,0,160.86,95.14ZM200,68.68,187.32,56,212,31.31,224.69,44ZM93.66,194.33a8,8,0,0,1-11.31,11.32l-32-32a8,8,0,0,1,11.32-11.31Z"/>')}</span>`;
    const _esc = (s) => { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };
    const _norm = (url) => (url || '').replace(/\/$/, '') || '/';

    // Pesi del merge: condividere un autore conta di più che condividere un
    // periodo storico, che conta più di condividere un singolo tag.
    const WEIGHT_AUTORI  = 5;
    const WEIGHT_PERIODO = 3;
    const WEIGHT_TAGS    = 2;

    class MoreLikeThis extends HTMLElement {
      async connectedCallback() {
        const autori     = JSON.parse(this.dataset.autori || '[]');
        const tags       = JSON.parse(this.dataset.tags || '[]');
        const periodo    = this.dataset.periodo || '';
        const excludeUrl = _norm(this.dataset.excludeUrl);
        const pageSize   = parseInt(this.dataset.pageSize || '4', 10);
        const resultsEl  = this.querySelector('[data-mlt-results]');
        if (!resultsEl || (autori.length === 0 && tags.length === 0 && !periodo)) return;

        try {
          const pf = await import('/pagefind/pagefind.js');
          await pf.init();

          const scored = new Map(); // url -> { item, score }
          const addMatches = async (filterValue, weight) => {
            const search = await pf.search(null, { filters: { type: 'canti', ...filterValue } });
            const items = await Promise.all(search.results.map((r) => r.data()));
            for (const item of items) {
              const url = _norm(item.url);
              if (url === excludeUrl) continue;
              const entry = scored.get(url);
              if (entry) entry.score += weight;
              else scored.set(url, { item, score: weight });
            }
          };

          await Promise.all([
            autori.length > 0 ? addMatches({ autori }, WEIGHT_AUTORI) : null,
            periodo ? addMatches({ periodi: periodo }, WEIGHT_PERIODO) : null,
            tags.length > 0 ? addMatches({ tags }, WEIGHT_TAGS) : null,
          ]);

          const top = [...scored.values()]
            .sort((a, b) => b.score - a.score)
            .slice(0, pageSize)
            .map((entry) => entry.item);
          if (top.length === 0) return;

          resultsEl.innerHTML = top.map((item) => this._card(item)).join('');
          this.classList.remove('hidden');
        } catch (e) {
          console.error('[more-like-this]', e);
        }
      }

      _card(item) {
        const meta    = item.meta || {};
        const url     = _norm(item.url);
        const accordi = meta.accordi === 'sì';
        const audio   = meta.audio === 'sì';
        const e       = _esc;
        return `
          <div class="flex flex-col gap-1 py-3 hover:bg-base-200 transition-colors rounded-lg">
            <h3 class="font-serif font-semibold text-primary flex items-center gap-2">
              <a href="${e(url)}" class="hover:underline">${e(meta.title)}</a>
              ${headphones(audio ? 'text-primary' : 'text-base-content/30')}
              ${guitar(accordi ? 'text-primary' : 'text-base-content/30')}
            </h3>
            ${meta.autori ? `<p class="text-base text-base-content/60">${e(meta.autori)}</p>` : ''}
          </div>
        `;
      }
    }

    if (!customElements.get('more-like-this')) {
      customElements.define('more-like-this', MoreLikeThis);
    }
  })();
</script>
