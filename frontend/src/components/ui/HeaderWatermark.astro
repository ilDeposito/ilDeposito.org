---
import { Image } from 'astro:assets';
import { getPeriodoWatermarkCasuale } from '../../lib/api/index.js';

const watermark = await getPeriodoWatermarkCasuale();
---

{watermark && (
  <Image
    src={watermark.url}
    alt=""
    width={1600}
    height={400}
    format="webp"
    quality={65}
    loading="eager"
    class="absolute inset-0 w-full h-full object-cover object-top md:object-center opacity-10 grayscale pointer-events-none select-none"
  />
)}
