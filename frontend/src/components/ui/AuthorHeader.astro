---
import { Image } from 'astro:assets';
import type { AutoreDetail } from '../../lib/api/types.js';
import { getImageUrl } from '../../lib/api/index.js';
import Breadcrumb from './Breadcrumb.astro';
import ShareModal from './ShareModal.astro';
import Icon from '../base/Icon.astro';
import AutorePlaceholder from './AutorePlaceholder.astro';

interface Props {
  autore: AutoreDetail;
  breadcrumbItems?: Array<{ label: string; href?: string }>;
  cantiSlug?: string;
}

const { autore, breadcrumbItems, cantiSlug } = Astro.props;

let anni: string | null = null;
if (autore.annoNascita && autore.annoMorte) anni = `${autore.annoNascita} - ${autore.annoMorte}`;
else if (autore.annoNascita) anni = `${autore.annoNascita}`;
else if (autore.annoMorte) anni = `${autore.annoMorte}`;

const immagineUrl = getImageUrl(autore.immagine);
---
<header class="bg-base-200 border-b-2 border-secondary">
  <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
    {breadcrumbItems && <Breadcrumb items={breadcrumbItems} />}

    <div class="flex items-center gap-4">
      {immagineUrl ? (
        <Image
          src={immagineUrl}
          alt={"Foto di " + autore.titolo}
          width={160}
          height={160}
          format="webp"
          quality={80}
          loading="eager"
          fetchpriority="high"
          data-pagefind-meta="image[src]"
          class="w-20 h-20 rounded-full object-cover shrink-0 border-2 border-base-300"
        />
      ) : (
        <AutorePlaceholder
          nome={autore.nome}
          cognome={autore.cognome}
          titolo={autore.titolo}
          textClass="text-2xl md:text-3xl"
          class="w-20 h-20 shrink-0"
        />
      )}
      <div class="flex flex-col gap-1">
        <h1 class="font-serif font-bold text-2xl md:text-3xl text-base-content">{autore.titolo}</h1>
        {(autore.localizzazioni.length > 0 || anni) && (
          <p class="font-serif italic text-base text-base-content/70">
            {autore.localizzazioni.map((l, i) => (
              <>
                {i > 0 && ', '}
                <a href={`/localizzazioni/${l.slug}`} class="text-primary underline hover:no-underline">{l.titolo}</a>
              </>
            ))}
            {anni && <> · {anni}</>}
          </p>
        )}
      </div>
    </div>

    {cantiSlug && (
      <a href={`/autori/${cantiSlug}`} class="btn btn-primary gap-1 w-fit border-0">
        <Icon name="music-notes" />
        Tutti i canti
      </a>
    )}

    <share-button data-title={autore.titolo} class="contents">
      <button type="button" class="inline-flex items-center gap-1 cursor-pointer w-fit" aria-label="Condividi questo autore">
        <Icon name="share-network" />
        Condividi
      </button>
      <ShareModal pageType="autore" />
    </share-button>
  </div>
</header>

<script>
  import '../../scripts/share-button.js';
</script>
