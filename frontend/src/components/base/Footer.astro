---
import logoRaw from '../../assets/images/ildeposito-logo.svg?raw';
import Icon from './Icon.astro';

const buildDate = import.meta.env.BUILD_DATE;
---

<footer class="w-full font-sans" style="content-visibility:auto;contain-intrinsic-size:auto 400px">

  <!-- Linea decorativa rossa superiore -->
  <div class="h-[2px] w-full bg-primary"></div>

  <!-- Corpo footer -->
  <div class="bg-neutral text-neutral-content py-6">
  <div class="max-w-6xl mx-auto px-4 flex flex-col gap-5">

    <!-- Identità -->
    <div class="flex flex-col gap-1">
      <div class="flex items-center gap-2">
        <span class="shrink-0 inline-flex items-center [&>svg]:h-8 [&>svg]:w-auto">
          <Fragment set:html={logoRaw} />
        </span>
        <span class="font-serif font-bold text-2xl tracking-wide">ilDeposito</span>
      </div>
      <p class="font-serif italic text-sm">
        canti di protesta politica e sociale
      </p>
    </div>

    <hr class="border-none h-px bg-neutral-content/20" />

    <!-- ARCHIVIO -->
    <nav aria-label="Archivio">
      <p class="font-serif font-bold tracking-widest text-sm uppercase mb-2">
        ARCHIVIO
      </p>
      <div class="grid grid-cols-2 text-base leading-[2.4]">
        <div class="flex flex-col">
          <a href="/canti">Canti</a>
          <a href="/autori">Autori</a>
          <a href="/periodi">Periodi storici</a>
        </div>
        <div class="flex flex-col">
          <a href="/eventi">Eventi</a>
          <a href="/tags">Tag</a>
          <a href="/archivio/storia-cantata">Storia cantata</a>
        </div>
      </div>
    </nav>

    <hr class="border-none h-px bg-neutral-content/20" />

    <!-- PROGETTO -->
    <nav aria-label="Progetto">
      <p class="font-serif font-bold tracking-widest text-sm uppercase mb-2">
        PROGETTO
      </p>
      <div class="grid grid-cols-2 text-base leading-[2.4]">
        <div class="flex flex-col">
          <a href="/informazioni">Informazioni</a>
          <a href="/informazioni/collabora">Collabora</a>
        </div>
        <div class="flex flex-col">
          <a href="/informazioni/chi-siamo">Chi siamo</a>
          <a href="/informazioni/contatti">Contatti</a>
        </div>
      </div>
    </nav>

    <hr class="border-none h-px bg-neutral-content/20" />

    <!-- Seguici -->
    <div class="flex flex-col gap-2">
      <p class="text-sm">Seguici</p>
      <div class="flex items-center gap-4">
        <a href="https://www.facebook.com/ildeposito.org" target="_blank" rel="noopener noreferrer" aria-label="ilDeposito su Facebook">
          <Icon name="facebook-logo-fill" class="text-5xl" />
        </a>
        <a href="https://www.youtube.com/user/ildeposito" target="_blank" rel="noopener noreferrer" aria-label="ilDeposito su YouTube">
          <Icon name="youtube-logo-fill" class="text-5xl" />
        </a>
        <a href="https://github.com/ilDeposito/ilDeposito.org" target="_blank" rel="noopener noreferrer" aria-label="ilDeposito su GitHub">
          <Icon name="github-logo-fill" class="text-5xl" />
        </a>
      </div>
    </div>

    <hr class="border-none h-px bg-neutral-content/20" />

    <!-- Copyright -->
    <p class="text-neutral-content/60 text-sm leading-relaxed text-center">
      ilDeposito.org è un progetto collettivo, online dal 4 ottobre 2004<br />
      I diritti dei testi e degli accordi sono dei rispettivi autori<br />
      <a href="/informazioni">informazioni</a> · <a href="/informazioni/privacy">privacy</a> · <a href="/informazioni/contatti">contatti</a>
    </p>

    <p class="text-neutral-content/30 text-xs text-right">{buildDate ? `Last build: ${buildDate}` : 'build dev'}</p>

  </div>
  </div>
</footer>
