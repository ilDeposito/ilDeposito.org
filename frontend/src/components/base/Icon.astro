---
import arrowDown from '@phosphor-icons/core/assets/regular/arrow-down.svg?raw';
import arrowLeft from '@phosphor-icons/core/assets/regular/arrow-left.svg?raw';
import arrowRight from '@phosphor-icons/core/assets/regular/arrow-right.svg?raw';
import calendarBlank from '@phosphor-icons/core/assets/regular/calendar-blank.svg?raw';
import calendarStar from '@phosphor-icons/core/assets/regular/calendar-star.svg?raw';
import caretDown from '@phosphor-icons/core/assets/regular/caret-down.svg?raw';
import caretRight from '@phosphor-icons/core/assets/regular/caret-right.svg?raw';
import check from '@phosphor-icons/core/assets/regular/check.svg?raw';
import copy from '@phosphor-icons/core/assets/regular/copy.svg?raw';
import envelope from '@phosphor-icons/core/assets/regular/envelope.svg?raw';
import facebookLogo from '@phosphor-icons/core/assets/regular/facebook-logo.svg?raw';
import filePdf from '@phosphor-icons/core/assets/regular/file-pdf.svg?raw';
import funnel from '@phosphor-icons/core/assets/regular/funnel.svg?raw';
import funnelX from '@phosphor-icons/core/assets/regular/funnel-x.svg?raw';
import guitar from '@phosphor-icons/core/assets/regular/guitar.svg?raw';
import headphones from '@phosphor-icons/core/assets/regular/headphones.svg?raw';
import house from '@phosphor-icons/core/assets/regular/house.svg?raw';
import imageBroken from '@phosphor-icons/core/assets/regular/image-broken.svg?raw';
import list from '@phosphor-icons/core/assets/regular/list.svg?raw';
import magnifyingGlass from '@phosphor-icons/core/assets/regular/magnifying-glass.svg?raw';
import mapPin from '@phosphor-icons/core/assets/regular/map-pin.svg?raw';
import musicNotes from '@phosphor-icons/core/assets/regular/music-notes.svg?raw';
import pauseFill from '@phosphor-icons/core/assets/fill/pause-fill.svg?raw';
import play from '@phosphor-icons/core/assets/regular/play.svg?raw';
import playFill from '@phosphor-icons/core/assets/fill/play-fill.svg?raw';
import shareNetwork from '@phosphor-icons/core/assets/regular/share-network.svg?raw';
import telegramLogo from '@phosphor-icons/core/assets/regular/telegram-logo.svg?raw';
import user from '@phosphor-icons/core/assets/regular/user.svg?raw';
import whatsappLogo from '@phosphor-icons/core/assets/regular/whatsapp-logo.svg?raw';
import x from '@phosphor-icons/core/assets/regular/x.svg?raw';
import xLogo from '@phosphor-icons/core/assets/regular/x-logo.svg?raw';
import handFist from '@phosphor-icons/core/assets/regular/hand-fist.svg?raw';
import quotes from '@phosphor-icons/core/assets/regular/quotes.svg?raw';
import tag from '@phosphor-icons/core/assets/regular/tag.svg?raw';
import usersThree from '@phosphor-icons/core/assets/regular/users-three.svg?raw';
import books from '@phosphor-icons/core/assets/regular/books.svg?raw';

import facebookLogoFill from '@phosphor-icons/core/assets/fill/facebook-logo-fill.svg?raw';
import youtubeLogo from '@phosphor-icons/core/assets/fill/youtube-logo-fill.svg?raw';
import githubLogoFill from '@phosphor-icons/core/assets/fill/github-logo-fill.svg?raw';
import pencilSimple from '@phosphor-icons/core/assets/regular/pencil-simple.svg?raw';
import warningCircle from '@phosphor-icons/core/assets/regular/warning-circle.svg?raw';
import paperPlaneTilt from '@phosphor-icons/core/assets/regular/paper-plane-tilt.svg?raw';
import checkCircle from '@phosphor-icons/core/assets/regular/check-circle.svg?raw';

const icons: Record<string, string> = {
  'arrow-down': arrowDown,
  'arrow-left': arrowLeft,
  'arrow-right': arrowRight,
  'calendar-blank': calendarBlank,
  'calendar-star': calendarStar,
  'caret-down': caretDown,
  'caret-right': caretRight,
  'check': check,
  'copy': copy,
  'envelope': envelope,
  'facebook-logo': facebookLogo,
  'file-pdf': filePdf,
  'funnel': funnel,
  'funnel-x': funnelX,
  'guitar': guitar,
  'headphones': headphones,
  'house': house,
  'image-broken': imageBroken,
  'list': list,
  'magnifying-glass': magnifyingGlass,
  'map-pin': mapPin,
  'music-notes': musicNotes,
  'pause': pauseFill,
  'play': play,
  'play-fill': playFill,
  'share-network': shareNetwork,
  'telegram-logo': telegramLogo,
  'user': user,
  'whatsapp-logo': whatsappLogo,
  'x': x,
  'x-logo': xLogo,
  'hand-fist': handFist,
  'quotes': quotes,
  'tag': tag,
  'users-three': usersThree,
  'books': books,
  'facebook-logo-fill': facebookLogoFill,
  'youtube-logo-fill': youtubeLogo,
  'github-logo-fill': githubLogoFill,
  'pencil-simple': pencilSimple,
  'warning-circle': warningCircle,
  'paper-plane-tilt': paperPlaneTilt,
  'check-circle': checkCircle,
};

interface Props {
  name: string;
  class?: string;
  label?: string;
}

const { name, class: className, label } = Astro.props;
const svg = icons[name] ?? '';
---
{label ? (
  <span role="img" aria-label={label} class:list={["inline-flex items-center justify-center shrink-0 [&>svg]:w-[1em] [&>svg]:h-[1em]", className]} set:html={svg} />
) : (
  <span aria-hidden="true" class:list={["inline-flex items-center justify-center shrink-0 [&>svg]:w-[1em] [&>svg]:h-[1em]", className]} set:html={svg} />
)}
