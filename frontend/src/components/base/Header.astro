---
import logoRaw from '../../assets/images/ildeposito-logo.svg?raw';
import Icon from './Icon.astro';

const { pathname } = Astro.url;
const isCurrent = (href: string) => pathname === href || pathname.startsWith(`${href}/`);
---
<header class="sticky top-0 z-50 w-full bg-primary">
  <div class="max-w-6xl mx-auto flex items-center gap-3 px-4 h-14 md:h-16">

    <!-- Logo + Site name -->
    <a
      href="/"
      aria-label="ilDeposito - home"
      class="shrink-0 inline-flex items-center gap-2 text-primary-content [&_svg]:h-8 [&_svg]:w-auto md:[&_svg]:h-10"
    >
      <span aria-hidden="true" class="contents"><Fragment set:html={logoRaw} /></span>
      <span class="hidden md:inline font-serif font-bold text-2xl tracking-wide">ilDeposito.org</span>
    </a>

    <!-- Spacer sx -->
    <div class="hidden md:block flex-1"></div>

    <!-- Nav desktop -->
    <nav aria-label="Navigazione principale" class="hidden md:flex items-center gap-3">
      <a href="/canti" aria-current={isCurrent('/canti') ? 'page' : undefined} class="px-4 py-1.5 rounded text-xl font-serif uppercase tracking-wide text-primary-content hover:bg-primary-content/15 transition-colors">Canti</a>
      <a href="/autori" aria-current={isCurrent('/autori') ? 'page' : undefined} class="px-4 py-1.5 rounded text-xl font-serif uppercase tracking-wide text-primary-content hover:bg-primary-content/15 transition-colors">Autori</a>
      <a href="/periodi" aria-current={isCurrent('/periodi') ? 'page' : undefined} class="px-4 py-1.5 rounded text-xl font-serif uppercase tracking-wide text-primary-content hover:bg-primary-content/15 transition-colors">Periodi</a>
      <a href="/eventi" aria-current={isCurrent('/eventi') ? 'page' : undefined} class="px-4 py-1.5 rounded text-xl font-serif uppercase tracking-wide text-primary-content hover:bg-primary-content/15 transition-colors">Eventi</a>
    </nav>

    <!-- Spacer dx -->
    <div class="hidden md:block flex-1"></div>

    <!-- Search -->
    <search-modal class="relative flex-1 md:w-64 md:flex-none">
      <form action="/cerca" method="get" data-search-form>
        <div class="flex items-center bg-primary-content/15 rounded-lg px-3 h-9 gap-2 focus-within:ring-2 focus-within:ring-primary-content">
          <input
            type="search"
            name="q"
            data-search-input
            autocomplete="off"
            placeholder="cerca canti, autori.."
            aria-label="Cerca canti o autori"
            class="
              flex-1 bg-transparent text-primary-content placeholder:text-primary-content/85
              placeholder:italic text-base font-sans focus-visible:outline-none min-w-0
            "
          />
          <button
            type="submit"
            aria-label="Cerca"
            class="shrink-0 text-primary-content cursor-pointer bg-transparent border-0 p-1.5 -m-1.5 inline-flex items-center focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary-content rounded"
          >
            <Icon name="magnifying-glass" />
          </button>
        </div>
      </form>
      <ul
        data-search-results
        class="menu hidden absolute left-0 right-0 top-full mt-2 bg-base-100 text-base-content rounded-box shadow-lg border border-base-300 max-h-80 overflow-y-auto flex-nowrap z-50"
      ></ul>
      <span data-search-status role="status" class="sr-only"></span>
    </search-modal>

    <!-- Hamburger -->
    <nav-hamburger class="contents">
      <button
        type="button"
        data-menu-toggle
        aria-label="Apri menu"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        class="shrink-0 text-primary-content cursor-pointer p-1.5 -m-1.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary-content rounded"
      >
        <Icon name="list" class="text-2xl" />
      </button>

      <dialog
        id="mobile-menu-panel"
        data-menu-panel
        aria-label="Menu"
        class="hidden open:flex m-0 p-0 max-w-none max-h-none w-full h-full flex-col bg-base-100 text-base-content"
      >
        <div class="border-b border-base-300">
          <div class="max-w-6xl mx-auto px-5 py-4 flex items-center justify-between">
            <a href="/" class="font-serif font-bold text-xl text-primary" data-menu-close>ilDeposito.org</a>
            <button
              type="button"
              data-menu-close
              aria-label="Chiudi menu"
              class="cursor-pointer p-1.5 -m-1.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary rounded"
            >
              <Icon name="x" class="text-2xl" />
            </button>
          </div>
        </div>

        <nav class="flex-1 overflow-y-auto" aria-label="Menu di navigazione">
          <div class="max-w-6xl mx-auto px-5 py-6">
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-1">
              <li>
                <a href="/canti" class="block py-3 group">
                  <span class="font-serif font-bold text-2xl md:text-3xl text-base-content group-hover:text-primary transition-colors">Canti</span>
                  <span class="block text-sm font-sans text-base-content/70 mt-0.5">Testi, accordi e informazioni dei canti di protesta</span>
                </a>
              </li>
              <li>
                <a href="/autori" class="block py-3 group">
                  <span class="font-serif font-bold text-2xl md:text-3xl text-base-content group-hover:text-primary transition-colors">Autori</span>
                  <span class="block text-sm font-sans text-base-content/70 mt-0.5">Compositori e autori dei canti dell'archivio</span>
                </a>
              </li>
              <li>
                <a href="/eventi" class="block py-3 group">
                  <span class="font-serif font-bold text-2xl md:text-3xl text-base-content group-hover:text-primary transition-colors">Eventi</span>
                  <span class="block text-sm font-sans text-base-content/70 mt-0.5">Gli eventi storici legati ai canti di protesta</span>
                </a>
              </li>
              <li>
                <a href="/archivio/storia-cantata" class="block py-3 group">
                  <span class="font-serif font-bold text-2xl md:text-3xl text-base-content group-hover:text-primary transition-colors">La storia cantata</span>
                  <span class="block text-sm font-sans text-base-content/70 mt-0.5">Esplora la storia attraverso i canti e gli eventi</span>
                </a>
              </li>
              <li>
                <a href="/periodi" class="block py-3 group">
                  <span class="font-serif font-bold text-2xl md:text-3xl text-base-content group-hover:text-primary transition-colors">Periodi</span>
                  <span class="block text-sm font-sans text-base-content/70 mt-0.5">I periodi storici dell'archivio</span>
                </a>
              </li>
              <li>
                <a href="/tags" class="block py-3 group">
                  <span class="font-serif font-bold text-2xl md:text-3xl text-base-content group-hover:text-primary transition-colors">Tags</span>
                  <span class="block text-sm font-sans text-base-content/70 mt-0.5">I temi e gli argomenti dei canti</span>
                </a>
              </li>
            </ul>

            <div class="border-t border-base-300 my-5"></div>

            <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-1">
              <li><a href="/archivio" class="block py-2 text-xl font-sans text-base-content/70 hover:text-primary transition-colors">Archivio</a></li>
              <li><a href="/traduzioni" class="block py-2 text-xl font-sans text-base-content/70 hover:text-primary transition-colors">Traduzioni</a></li>
              <li><a href="/lingue" class="block py-2 text-xl font-sans text-base-content/70 hover:text-primary transition-colors">Lingue</a></li>
              <li><a href="/localizzazioni" class="block py-2 text-xl font-sans text-base-content/70 hover:text-primary transition-colors">Localizzazioni</a></li>
            </ul>

            <div class="border-t border-base-300 my-5"></div>

            <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-1">
              <li><a href="/informazioni" class="block py-2 text-lg font-sans text-base-content/70 hover:text-primary transition-colors">Informazioni</a></li>
              <li><a href="/informazioni/collabora" class="block py-2 text-lg font-sans text-base-content/70 hover:text-primary transition-colors">Collabora</a></li>
              <li><a href="/informazioni/contatti" class="block py-2 text-lg font-sans text-base-content/70 hover:text-primary transition-colors">Contatti</a></li>
              <li><a href="/informazioni/social" class="block py-2 text-lg font-sans text-base-content/70 hover:text-primary transition-colors">Canali Social</a></li>
            </ul>
          </div>
        </nav>
      </dialog>
    </nav-hamburger>

  </div>
</header>

<script>
  import '../../scripts/nav-hamburger.js';
</script>

<script is:inline>
if (!customElements.get('search-modal')) {
  const _esc = (s) => {
    if (!s) return '';
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  };

  class SearchModal extends HTMLElement {
    connectedCallback() {
      const init = () => {
        const input   = this.querySelector('[data-search-input]');
        const results = this.querySelector('[data-search-results]');
        const form    = this.querySelector('[data-search-form]');
        const status  = this.querySelector('[data-search-status]');
        let pf, debounce;

        const close = () => {
          results.classList.add('hidden');
          results.innerHTML = '';
          if (status) status.textContent = '';
        };

        form?.addEventListener('submit', (e) => {
          if (!input.value.trim()) e.preventDefault();
        });

        input.addEventListener('input', () => {
          clearTimeout(debounce);
          const q = input.value.trim();
          if (!q) { close(); return; }
          debounce = setTimeout(async () => {
            if (!pf) {
              pf = await import('/pagefind/pagefind.js');
              await pf.init();
            }
            const search = await pf.search(q);
            const data   = await Promise.all(search.results.slice(0, 8).map((x) => x.data()));
            results.innerHTML = data.length
              ? data.map((x) => `<li><a href="${_esc(x.url)}">${_esc(x.meta.title)} <span class="text-base-content/70">[${_esc(x.meta.type)}]</span></a></li>`).join('')
              : '<li><span class="text-base-content/70">Nessun risultato</span></li>';
            results.classList.remove('hidden');
            if (status) status.textContent = data.length ? `${data.length} suggeriment${data.length === 1 ? 'o' : 'i'} disponibil${data.length === 1 ? 'e' : 'i'}` : 'Nessun suggerimento disponibile';
          }, 200);
        });

        input.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !results.classList.contains('hidden')) {
            e.stopPropagation();
            close();
          }
        });

        document.addEventListener('click', (e) => {
          if (!this.contains(e.target)) close();
        });
      };

      document.readyState === 'loading'
        ? document.addEventListener('DOMContentLoaded', init, { once: true })
        : init();
    }
  }

  customElements.define('search-modal', SearchModal);
}
</script>
