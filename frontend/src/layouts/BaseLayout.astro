---
import '../styles/main.css';
import Header from '../components/base/Header.astro';
import EventBar from '../components/base/EventBar.astro';
import Footer from '../components/base/Footer.astro';
import SEO from '../components/base/SEO.astro';
import { buildTitle, buildDescription, buildCanonical, resolveOgImage } from '../lib/seo.js';

import sourceSansLatin400 from '@fontsource/source-sans-3/files/source-sans-3-latin-400-normal.woff2?url';
import sourceSansLatin600 from '@fontsource/source-sans-3/files/source-sans-3-latin-600-normal.woff2?url';
import bitterLatin400 from '@fontsource/bitter/files/bitter-latin-400-normal.woff2?url';
import bitterLatin700 from '@fontsource/bitter/files/bitter-latin-700-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  pagefindType?: string;
  pagefindTitle?: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  publishedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  profileFirstName?: string;
  profileLastName?: string;
  jsonLd?: object | object[];
  preloadImage?: string;
  dnsPrefetch?: string[];
}

const {
  title,
  description = '',
  pagefindType,
  pagefindTitle,
  canonical,
  ogType,
  ogImage,
  ogImageAlt,
  noindex = false,
  publishedTime,
  articleSection,
  articleTags,
  profileFirstName,
  profileLastName,
  jsonLd,
  preloadImage,
  dnsPrefetch,
} = Astro.props;

const seoTitle = buildTitle(title);
const seoDescription = buildDescription(description);
const seoCanonical = canonical || buildCanonical(Astro);
const seoOgImage = resolveOgImage(ogImage || '/og-default.jpg', Astro.site);

// ENV è passato al container astro-builder solo in stage/prod (compose.{stage,prod}.yml),
// assente in dev locale: le statistiche girano solo sulla build di produzione.
const isProduction = process.env.ENV === 'prod';
---
<!DOCTYPE html>
<html lang="it" data-theme="ildeposito">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#9E1B1B" />
    <link rel="preload" as="font" type="font/woff2" href={sourceSansLatin400} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={sourceSansLatin600} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={bitterLatin400} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={bitterLatin700} crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="ilDeposito.org — Nuovi canti" href="/rss.xml" />
    {dnsPrefetch?.map((url) => <link rel="dns-prefetch" href={url} />)}
    {preloadImage && <link rel="preload" as="image" href={preloadImage} />}
    <SEO
      title={seoTitle}
      description={seoDescription}
      canonical={seoCanonical}
      ogType={ogType}
      ogImage={seoOgImage}
      ogImageAlt={ogImageAlt}
      noindex={noindex}
      publishedTime={publishedTime}
      articleSection={articleSection}
      articleTags={articleTags}
      profileFirstName={profileFirstName}
      profileLastName={profileLastName}
      jsonLd={jsonLd}
    />
    {isProduction && (
      <script is:inline defer src="https://umami.ildeposito.org/script.js" data-website-id="fb52ac28-2b96-4c18-9c8e-0ed6ad3c5ff1"></script>
    )}
  </head>
  <body class="font-sans bg-base-100 text-base-content">
    <Header />
    <EventBar />
    <main>
      {pagefindType && (
        <span aria-hidden="true" class="sr-only">
          <span data-pagefind-meta="title">{pagefindTitle || title}</span>
          <span data-pagefind-meta={`type:${pagefindType}`}></span>
          <span data-pagefind-filter={`type:${pagefindType}`}></span>
        </span>
      )}
      <slot />
    </main>
    <Footer />
  </body>
</html>
