---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorHeader from '../../components/ui/AuthorHeader.astro';
import { getAutori, getAutore, getCantiByAutoreMap } from '../../lib/api/index.js';
import { buildPersonSchema, buildBreadcrumbSchema } from '../../lib/schema.js';

export async function getStaticPaths() {
  const autori = await getAutori();
  return autori.map((autore) => ({ params: { slug: autore.slug } }));
}

const { slug } = Astro.params;
const autore = (await getAutore(slug))!;

const cantiMap = await getCantiByAutoreMap();
const tuttiCanti = cantiMap.get(autore.id) ?? [];
const haPiuDiDieci = tuttiCanti.length > 10;

const canti = haPiuDiDieci
  ? [...tuttiCanti]
      .sort((a, b) => (b.visualizzazioni ?? 0) - (a.visualizzazioni ?? 0))
      .slice(0, 10)
  : [...tuttiCanti].sort((a, b) => a.titolo.localeCompare(b.titolo, 'it'));

const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Autori', href: '/autori' },
  { label: autore.titolo },
];
const jsonLd = [
  buildPersonSchema(autore, siteUrl),
  buildBreadcrumbSchema(breadcrumbItems.map((item) => ({ name: item.label, url: item.href ? `${siteUrl}${item.href}` : undefined }))),
];
---
<BaseLayout
  title={autore.titolo}
  description={autore.informazioni || `${autore.titolo} — autore nell'archivio di ilDeposito.org`}
  pagefindType="autori"
  ogType="profile"
  jsonLd={jsonLd}
>

  <AuthorHeader autore={autore} breadcrumbItems={breadcrumbItems} />

  <div class="max-w-6xl mx-auto px-4 py-8">
  <article data-pagefind-body class="flex flex-col gap-6 max-w-2xl mx-auto">

    <!-- Metadati Pagefind (nascosti, per facet e display nell'elenco) -->
    <span class="sr-only" data-pagefind-weight="10">{autore.titolo}</span>
    <span class="sr-only" data-pagefind-sort="titolo">{autore.titolo}</span>
    <span class="sr-only" data-pagefind-meta={`num_canti:${tuttiCanti.length}`}></span>
    {autore.localizzazioni.length > 0 && (
      <span class="sr-only" data-pagefind-meta={`localizzazioni:${autore.localizzazioni.map((l) => l.titolo).join(', ')}`}></span>
    )}
    {autore.localizzazioni.map((l) => (
      <span class="sr-only" data-pagefind-filter={`localizzazioni:${l.titolo}`}></span>
    ))}
    {autore.periodi.map((p) => (
      <span class="sr-only" data-pagefind-filter={`periodi:${p.titolo}`}></span>
    ))}

    <!-- I canti principali -->
    {canti.length > 0 && (
      <section data-pagefind-ignore class="flex flex-col gap-2">
        <h2 class="font-serif font-bold text-lg md:text-xl text-base-content text-center w-fit mx-auto border-b-2 border-secondary pb-2">
          I canti principali
        </h2>

        <div class="flex flex-col divide-y divide-base-300">
          {canti.map((canto) => (
            <div class="flex flex-col gap-1 py-3 hover:bg-base-200 transition-colors rounded-lg">
              <p class="text-sm text-base-content/50 flex items-center gap-2">
                {canto.anno && <span class="italic">{canto.anno}</span>}
                {canto.anno && <span>·</span>}
                <i class={`ph ph-headphones ${canto.videoUrl ? 'text-primary' : 'text-base-content/30'}`}></i>
                <i class={`ph ph-guitar ${canto.accordi ? 'text-primary' : 'text-base-content/30'}`}></i>
              </p>
              <h3 class="font-serif font-bold text-primary">
                <a href={`/canti/${canto.slug}`} class="hover:underline">{canto.titolo}</a>
              </h3>
              {canto.capoverso && (
                <p class="italic text-base text-base-content/60">{canto.capoverso}</p>
              )}
            </div>
          ))}
        </div>

        {haPiuDiDieci && (
          <a href={`/autori/${autore.slug}/canti`} class="btn btn-primary self-center mt-2">
            <i class="ph ph-arrow-right"></i>
            Tutti i canti
          </a>
        )}
      </section>
    )}

    <!-- Informazioni -->
    {autore.informazioni && (
      <section class="flex flex-col gap-2">
        <h2 class="font-serif font-bold text-lg md:text-xl text-base-content">Informazioni</h2>
        <div class="text-base text-base-content/80 leading-relaxed [&_a]:text-primary [&_a]:underline" set:html={autore.informazioni} />
      </section>
    )}

  </article>
  </div>
</BaseLayout>
