---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AuthorHeader from '../../../components/ui/AuthorHeader.astro';
import PagefindList from '../../../components/ui/PagefindList.astro';
import { getAutori, getAutore, getCantiByAutoreMap } from '../../../lib/api/index.js';
import { buildCollectionPageSchema, buildBreadcrumbSchema } from '../../../lib/schema.js';
import { buildCanonical } from '../../../lib/seo.js';
import { getOgImageForAutore } from '../../../lib/og-image.js';

export async function getStaticPaths() {
  const autori = await getAutori();
  const cantiMap = await getCantiByAutoreMap();

  return autori
    .filter((autore) => (cantiMap.get(autore.id)?.length ?? 0) > 10)
    .map((autore) => ({ params: { slug: autore.slug } }));
}

const { slug } = Astro.params;
const autore = (await getAutore(slug))!;

const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const seoTitle = `Tutti i canti di ${autore.titolo}`;
const seoDescription = `L'elenco completo dei canti di ${autore.titolo} nell'archivio di ilDeposito.org: testi, accordi e informazioni.`;
const ogImage = await getOgImageForAutore(autore);
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Autori', href: '/autori' },
  { label: autore.titolo, href: `/autori/${autore.slug}` },
  { label: 'Canti' },
];
const jsonLd = [
  buildCollectionPageSchema(seoTitle, seoDescription, buildCanonical(Astro)),
  buildBreadcrumbSchema(breadcrumbItems.map((item) => ({ name: item.label, url: item.href ? `${siteUrl}${item.href}` : undefined }))),
];
---
<BaseLayout
  title={seoTitle}
  description={seoDescription}
  ogImage={ogImage}
  ogImageAlt={ogImage ? `Foto di ${autore.titolo}` : undefined}
  jsonLd={jsonLd}
>

  <AuthorHeader autore={autore} breadcrumbItems={breadcrumbItems} />

  <div class="max-w-6xl mx-auto px-4 py-8">
    <PagefindList
      type="canti"
      presetFilter={{ autori: autore.titolo }}
      filterKeys={["accordi", "audio", "tags"]}
      pageSize={15}
      sortOptions={[
        { field: 'titolo', label: 'A–Z', dir: 'asc' },
        { field: 'visualizzazioni', label: 'Più visti', dir: 'desc' },
        { field: 'visualizzazioni', label: 'Meno visti', dir: 'asc' },
      ]}
    />
  </div>

</BaseLayout>
