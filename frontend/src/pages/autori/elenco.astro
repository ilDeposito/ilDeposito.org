---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import PagefindList from '../../components/ui/PagefindList.astro';
---
<BaseLayout title="Gli autori dell'archivio" description="Elenco completo degli autori in ordine alfabetico">

  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-2">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Autori', href: '/autori' }, { label: 'Elenco' }]} />
      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">Gli autori dell'archivio</h1>
      <p class="font-serif italic text-base text-base-content/60">L'elenco completo degli autori in ordine alfabetico</p>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <div class="mt-6">
    <PagefindList
      type="autori"
      filterKeys={["localizzazioni", "periodi"]}
      pageSize={15}
      sortOptions={[
        { field: 'titolo', label: 'A–Z', dir: 'asc' },
        { field: 'visualizzazioni', label: 'Più visti', dir: 'desc' },
        { field: 'visualizzazioni', label: 'Meno visti', dir: 'asc' },
      ]}
    />
  </div>

  </div>
</BaseLayout>
