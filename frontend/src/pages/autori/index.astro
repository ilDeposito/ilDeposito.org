---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/base/Icon.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getAutoriPiuVisti, getCantiByAutoreMap, getImageUrl } from '../../lib/api/index.js';
import { buildCollectionPageSchema, buildBreadcrumbSchema } from '../../lib/schema.js';
import { buildCanonical } from '../../lib/seo.js';

const autori = await getAutoriPiuVisti(10);
const cantiMap = await getCantiByAutoreMap();

const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const seoDescription = 'Gli autori e compositori dei canti di protesta dell\'archivio: biografie, discografie e opere.';
const jsonLd = [
  buildCollectionPageSchema('Autori e compositori — Archivio', seoDescription, buildCanonical(Astro)),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Autori' },
  ]),
];

// TODO: rimuovere i dati fittizi quando gli anni saranno popolati nel CMS
const fakeYears: [number, number | null][] = [
  [1908, 1967], [1924, 1997], [1919, 2005],
  [1935, 2016], [1893, 1976], [1940, null],
  [1898, 1937], [1920, 1990], [1915, 1987],
  [1901, 1966],
];

const autoriConDati = autori.map((autore, i) => {
  const canti = cantiMap.get(autore.id) ?? [];
  const immagineUrl = getImageUrl(autore.immagine);
  const annoNascita = autore.annoNascita ?? fakeYears[i]?.[0] ?? null;
  const annoMorte = autore.annoMorte ?? fakeYears[i]?.[1] ?? null;
  return { autore, numCanti: canti.length, immagineUrl, annoNascita, annoMorte };
});
---
<BaseLayout title="Autori e compositori — Archivio" description={seoDescription} jsonLd={jsonLd}>

  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Autori' }]} />

      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">Gli autori dell'archivio</h1>

      <p class="font-serif italic text-base text-base-content/60">I compositori e autori dei canti</p>

      <a href="/autori/elenco" class="btn btn-primary btn-sm gap-2 w-fit border-0">
        Tutti gli autori dell'archivio
        <Icon name="arrow-right" />
      </a>
    </div>
  </header>

  <div class="max-w-6xl mx-auto px-4 py-8">

    <section class="flex flex-col gap-8 mt-2">
      <h2 class="font-serif font-bold text-lg md:text-xl text-base-content text-center w-fit mx-auto border-b-2 border-secondary pb-2">
        Gli autori più visitati
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10">
        {autoriConDati.map(({ autore, numCanti, immagineUrl, annoNascita, annoMorte }, i) => (
          <div class="flex items-start gap-5 group relative">
            <div class="shrink-0">
              {immagineUrl ? (
                <Image
                  src={immagineUrl}
                  alt={"Foto di " + autore.titolo}
                  width={240}
                  height={240}
                  format="webp"
                  quality={80}
                  loading={i < 4 ? 'eager' : 'lazy'}
                  class="w-32 h-32 md:w-36 md:h-36 rounded-full object-cover border-2 border-base-300 grayscale group-hover:grayscale-0 transition-all duration-300"
                />
              ) : (
                <div class="w-32 h-32 md:w-36 md:h-36 rounded-full bg-base-200 flex items-center justify-center border-2 border-base-300">
                  <Icon name="user" class="text-base-content/30 text-5xl" />
                </div>
              )}
            </div>

            <div class="flex flex-col gap-1.5 min-w-0 pt-2">
              <h3 class="font-serif font-bold text-xl md:text-2xl text-primary leading-tight">
                <a href={`/autori/${autore.slug}`} class="hover:underline after:absolute after:inset-0">{autore.titolo}</a>
              </h3>

              {(annoNascita || annoMorte) && (
                <p class="text-base text-base-content/50 flex items-center gap-2">
                  <Icon name="calendar-blank" class="text-sm shrink-0" />
                  {annoNascita}{annoMorte ? ` — ${annoMorte}` : ''}
                </p>
              )}

              {autore.localizzazioni.length > 0 && (
                <p class="text-base text-base-content/60 flex items-center gap-2 relative z-10">
                  <Icon name="map-pin" class="text-sm shrink-0" />
                  <span>
                    {autore.localizzazioni.map((l, j) => (
                      <>{j > 0 && ', '}<a href={`/localizzazioni/${l.slug}`} class="hover:text-primary hover:underline">{l.titolo}</a></>
                    ))}
                  </span>
                </p>
              )}

              {numCanti > 0 && (
                <p class="text-base text-base-content/50 flex items-center gap-2">
                  <Icon name="music-notes" class="text-sm shrink-0" />
                  {numCanti} {numCanti === 1 ? 'canto' : 'canti'}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>

      <a href="/autori/elenco" class="btn btn-primary self-center mt-4 gap-2">
        Tutti gli autori dell'archivio
        <Icon name="arrow-right" />
      </a>
    </section>

  </div>
</BaseLayout>
