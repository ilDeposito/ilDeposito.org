---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import HeaderWatermark from '../../components/ui/HeaderWatermark.astro';
import ShareModal from '../../components/ui/ShareModal.astro';
import Icon from '../../components/base/Icon.astro';
import { getLocalizzazioni, getContenutiByLocalizzazioneMap } from '../../lib/api/index.js';
import { buildCollectionPageSchema, buildBreadcrumbSchema } from '../../lib/schema.js';
import { buildCanonical } from '../../lib/seo.js';
import { getPageMeta } from '../../lib/pages.js';

const localizzazioni = await getLocalizzazioni();
const contenutiMap = await getContenutiByLocalizzazioneMap();

const meta = getPageMeta('localizzazioni.index');
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const jsonLd = [
  buildCollectionPageSchema(meta.metaTitle, meta.metaDescription, buildCanonical(Astro)),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Localizzazioni' },
  ]),
];
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription} jsonLd={jsonLd}>

  <!-- Titolo + info: attaccato all'header e ai bordi laterali -->
  <header class="relative overflow-hidden bg-base-200 border-b-2 border-secondary">
    <HeaderWatermark />
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Localizzazioni' }]} />

      <h1 class="font-serif font-bold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>

      <p class="font-serif italic text-base text-base-content/70">{meta.pageDescription}</p>

      <share-button data-title="Localizzazioni" class="contents">
        <button type="button" class="inline-flex items-center gap-1 cursor-pointer w-fit" aria-label="Condividi questa pagina">
          <Icon name="share-network" />
          Condividi
        </button>
        <ShareModal pageType="localizzazioni" />
      </share-button>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <ul role="list" class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto mt-6">
    {localizzazioni.map((localizzazione) => {
      const { autori = 0, eventi = 0 } = contenutiMap.get(localizzazione.id) ?? {};
      const parti = [
        autori > 0 && `${autori} ${autori === 1 ? 'autore' : 'autori'}`,
        eventi > 0 && `${eventi} ${eventi === 1 ? 'evento' : 'eventi'}`,
      ].filter(Boolean);

      return (
        <li class="flex flex-col gap-0.5 py-2">
          <a href={`/localizzazioni/${localizzazione.slug}`} class="font-serif font-semibold text-primary hover:underline">
            {localizzazione.titolo}
          </a>
          {parti.length > 0 && (
            <p class="font-serif italic text-base text-base-content/70">{parti.join(' · ')}</p>
          )}
        </li>
      );
    })}
  </ul>

  <script>
    import '../../scripts/share-button.js';
  </script>
  </div>
</BaseLayout>
