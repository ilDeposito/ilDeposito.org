---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import HeaderWatermark from '../../components/ui/HeaderWatermark.astro';
import PagefindList from '../../components/ui/PagefindList.astro';
import { getLocalizzazioni } from '../../lib/api/index.js';
import type { Tassonomia } from '../../lib/api/types.js';
import { buildDefinedTermSchema, buildBreadcrumbSchema } from '../../lib/schema.js';
import { buildCanonical } from '../../lib/seo.js';
import { getPageMeta } from '../../lib/pages.js';
import { getOgImageFallback } from '../../lib/og-image.js';

export async function getStaticPaths() {
  const localizzazioni = await getLocalizzazioni();
  return localizzazioni.map((localizzazione) => ({
    params: { slug: localizzazione.slug },
    props: { localizzazione },
  }));
}

const { localizzazione } = Astro.props as { localizzazione: Tassonomia };
const titolo = localizzazione.titolo.charAt(0).toUpperCase() + localizzazione.titolo.slice(1);
const meta = getPageMeta('localizzazioni.term', { titolo });
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const jsonLd = [
  buildDefinedTermSchema(titolo, meta.metaDescription, buildCanonical(Astro), {
    name: 'Localizzazioni',
    url: `${siteUrl}/localizzazioni`,
  }),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Localizzazioni', url: `${siteUrl}/localizzazioni` },
    { name: titolo },
  ]),
];
const ogImage = await getOgImageFallback();
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription} jsonLd={jsonLd} ogImage={ogImage}>

  <header class="relative overflow-hidden bg-base-200 border-b-2 border-secondary">
    <HeaderWatermark />
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-6 flex flex-col gap-2">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Localizzazioni', href: '/localizzazioni' }, { label: titolo }]} />
      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>
      <p class="font-serif italic text-base text-base-content/70">{meta.pageDescription}</p>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <div class="mt-6">
    <PagefindList
      presetFilter={{ localizzazioni: localizzazione.titolo }}
      filterKeys={["type", "periodi"]}
      pageSize={15}
      sortOptions={[
        { field: 'titolo', label: 'A–Z', dir: 'asc' },
        { field: 'visualizzazioni', label: 'Più visti', dir: 'desc' },
        { field: 'visualizzazioni', label: 'Meno visti', dir: 'asc' },
      ]}
    />
  </div>

  </div>
</BaseLayout>
