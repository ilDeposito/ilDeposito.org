---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildWebSiteSchema, buildOrganizationSchema, buildBreadcrumbSchema } from '../lib/schema.js';

const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const jsonLd = [
  buildWebSiteSchema(siteUrl),
  buildOrganizationSchema(siteUrl),
  buildBreadcrumbSchema([{ name: 'Home', url: siteUrl }]),
];
---
<BaseLayout
  title="Canti di protesta politica e sociale"
  description="Archivio online di canti di protesta politica e sociale: testi, accordi, traduzioni, autori e eventi storici."
  jsonLd={jsonLd}
>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="font-serif text-4xl md:text-5xl">Il Deposito</h1>
  </div>
</BaseLayout>
