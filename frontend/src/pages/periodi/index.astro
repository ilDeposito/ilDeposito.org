---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import HeaderWatermark from '../../components/ui/HeaderWatermark.astro';
import ShareModal from '../../components/ui/ShareModal.astro';
import Icon from '../../components/base/Icon.astro';
import { getPeriodi, getImageUrl, getContenutiByPeriodoMap } from '../../lib/api/index.js';
import { buildDefinedTermSetSchema, buildBreadcrumbSchema } from '../../lib/schema.js';
import { buildCanonical } from '../../lib/seo.js';
import { getPageMeta } from '../../lib/pages.js';

const periodi = await getPeriodi();
const contenutiMap = await getContenutiByPeriodoMap();

const meta = getPageMeta('periodi.index');
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const jsonLd = [
  buildDefinedTermSetSchema(meta.metaTitle, meta.metaDescription, buildCanonical(Astro)),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Periodi' },
  ]),
];
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription} jsonLd={jsonLd}>

  <header class="relative overflow-hidden bg-base-200 border-b-2 border-secondary">
    <HeaderWatermark />
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Periodi' }]} />

      <h1 class="font-serif font-bold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>

      <p class="font-serif italic text-base text-base-content/70">{meta.pageDescription}</p>

      <share-button data-title="Periodi storici" class="contents">
        <button type="button" class="inline-flex items-center gap-1 cursor-pointer w-fit" aria-label="Condividi questa pagina">
          <Icon name="share-network" />
          Condividi
        </button>
        <ShareModal pageType="periodi" />
      </share-button>
    </div>
  </header>

  <div class="max-w-6xl mx-auto px-4 py-8">

    <ul role="list" class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10 mt-6">
      {periodi.map((periodo, i) => {
        const { canti = 0, autori = 0, eventi = 0 } = contenutiMap.get(periodo.id) ?? {};
        const immagineUrl = getImageUrl(periodo.immagine);

        return (
          <li class="flex items-start gap-5 group relative">
            <div class="shrink-0">
              {immagineUrl ? (
                <Image
                  src={immagineUrl}
                  alt={"Immagine del periodo: " + periodo.titolo}
                  width={240}
                  height={240}
                  format="webp"
                  quality={80}
                  loading={i < 4 ? 'eager' : 'lazy'}
                  class="w-32 h-32 md:w-36 md:h-36 rounded-full object-cover border-2 border-base-300 grayscale group-hover:grayscale-0 transition-all duration-300"
                />
              ) : (
                <div class="w-32 h-32 md:w-36 md:h-36 rounded-full bg-base-200 flex items-center justify-center border-2 border-base-300">
                  <Icon name="calendar-star" class="text-base-content/50 text-5xl" />
                </div>
              )}
            </div>

            <div class="flex flex-col gap-2 min-w-0 pt-2">
              <h2 class="font-serif font-bold text-xl md:text-2xl text-primary leading-tight">
                <a href={`/periodi/${periodo.slug}`} class="hover:underline after:absolute after:inset-0">{periodo.titolo}</a>
              </h2>

              <div class="flex flex-wrap gap-x-5 gap-y-1.5">
                {canti > 0 && (
                  <p class="text-lg text-base-content/70 flex items-center gap-2">
                    <Icon name="music-notes" class="text-base text-primary/70 shrink-0" />
                    <span class="font-bold text-base-content">{canti}</span> {canti === 1 ? 'canto' : 'canti'}
                  </p>
                )}
                {autori > 0 && (
                  <p class="text-lg text-base-content/70 flex items-center gap-2">
                    <Icon name="user" class="text-base text-primary/70 shrink-0" />
                    <span class="font-bold text-base-content">{autori}</span> {autori === 1 ? 'autore' : 'autori'}
                  </p>
                )}
                {eventi > 0 && (
                  <p class="text-lg text-base-content/70 flex items-center gap-2">
                    <Icon name="calendar-star" class="text-base text-primary/70 shrink-0" />
                    <span class="font-bold text-base-content">{eventi}</span> {eventi === 1 ? 'evento' : 'eventi'}
                  </p>
                )}
              </div>
            </div>
          </li>
        );
      })}
    </ul>

  </div>

  <script>
    import '../../scripts/share-button.js';
  </script>
</BaseLayout>
