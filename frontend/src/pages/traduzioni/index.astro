---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import PagefindList from '../../components/ui/PagefindList.astro';
import { buildCollectionPageSchema, buildBreadcrumbSchema } from '../../lib/schema.js';
import { buildCanonical } from '../../lib/seo.js';

const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const seoDescription = 'Le traduzioni dei canti di protesta in tutte le lingue: testi tradotti, lingue originali e versioni alternative.';
const jsonLd = [
  buildCollectionPageSchema('Traduzioni dei canti — Archivio', seoDescription, buildCanonical(Astro)),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Traduzioni' },
  ]),
];
---
<BaseLayout title="Traduzioni dei canti — Archivio" description={seoDescription} jsonLd={jsonLd}>

  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-2">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Traduzioni' }]} />
      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">Le traduzioni dell'archivio</h1>
      <p class="font-serif italic text-base text-base-content/60">L'elenco completo delle traduzioni dell'archivio</p>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <div class="mt-6">
    <PagefindList
      type="traduzioni"
      filterKeys={["lingue"]}
      pageSize={15}
      sortOptions={[
        { field: 'titolo', label: 'A–Z', dir: 'asc' },
        { field: 'visualizzazioni', label: 'Più visti', dir: 'desc' },
        { field: 'visualizzazioni', label: 'Meno visti', dir: 'asc' },
      ]}
    />
  </div>

  </div>
</BaseLayout>
