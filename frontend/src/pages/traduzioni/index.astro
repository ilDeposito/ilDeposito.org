---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import PagefindList from '../../components/ui/PagefindList.astro';
---
<BaseLayout title="Le traduzioni dell'archivio" description="L'elenco completo delle traduzioni dell'archivio">

  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-2">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Traduzioni' }]} />
      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">Le traduzioni dell'archivio</h1>
      <p class="font-serif italic text-base text-base-content/60">L'elenco completo delle traduzioni dell'archivio</p>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <div class="mt-6">
    <PagefindList
      type="traduzioni"
      filterKeys={["lingue"]}
      pageSize={15}
    />
  </div>

  </div>
</BaseLayout>
