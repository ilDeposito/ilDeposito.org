---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import ShareModal from '../components/ui/ShareModal.astro';
import Icon from '../components/base/Icon.astro';
import ParagraphRenderer from '../components/paragraphs/ParagraphRenderer.astro';
import { getAllPagineDetail } from '../lib/api/index.js';
import type { PaginaDetail } from '../lib/api/types.js';
import { buildWebPageSchema, buildBreadcrumbSchema } from '../lib/schema.js';
import { buildCanonical, stripHtml } from '../lib/seo.js';

export async function getStaticPaths() {
  const allPagine = await getAllPagineDetail();
  return allPagine.map((pagina) => ({
    params: { percorso: pagina.percorso },
    props: { pagina },
  }));
}

const { pagina } = Astro.props as { pagina: PaginaDetail };

const description = pagina.descrizioneHeader ? stripHtml(pagina.descrizioneHeader) : '';

const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const jsonLd = [
  buildWebPageSchema(pagina.titolo, description, buildCanonical(Astro)),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: pagina.titolo },
  ]),
];
---
<BaseLayout title={pagina.titolo} description={description} jsonLd={jsonLd}>

  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-2">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: pagina.titolo }]} />
      <h1 class="font-serif font-bold text-2xl md:text-3xl text-base-content">{pagina.titolo}</h1>
      {pagina.descrizioneHeader && (
        <p class="text-base text-base-content/70 leading-relaxed" set:html={pagina.descrizioneHeader} />
      )}
      <div class="flex items-center gap-4 text-base text-base-content mt-1">
        <share-button data-title={pagina.titolo} class="contents">
          <button type="button" class="inline-flex items-center gap-1 cursor-pointer" aria-label="Condividi questa pagina">
            <Icon name="share-network" />
            Condividi
          </button>
          <ShareModal />
        </share-button>
      </div>
    </div>
  </header>

  <script>
    import '../scripts/share-button.js';
  </script>

  <div class="max-w-6xl mx-auto px-4">
    {pagina.paragraphs.map((paragraph) => (
      <ParagraphRenderer paragraph={paragraph} />
    ))}
  </div>

</BaseLayout>
