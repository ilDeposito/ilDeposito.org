---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/base/Icon.astro';
import { getPageMeta } from '../lib/pages.js';

const meta = getPageMeta('notFound');

const links = [
  { href: '/', label: 'Homepage', icon: 'house' },
  { href: '/canti', label: 'Canti', icon: 'music-notes' },
  { href: '/autori', label: 'Autori', icon: 'users-three' },
  { href: '/periodi', label: 'Periodi', icon: 'books' },
  { href: '/eventi', label: 'Eventi', icon: 'calendar-star' },
  { href: '/archivio/storia-cantata', label: 'La storia cantata', icon: 'hand-fist' },
];
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription} noindex={meta.noindex}>

  <section class="bg-neutral text-neutral-content">
    <div class="max-w-6xl mx-auto px-4 py-8 md:py-12 flex flex-col items-center text-center gap-3">
      <p class="font-serif font-bold text-xl md:text-2xl text-neutral-content/50">404</p>
      <h1 class="font-serif font-bold text-3xl md:text-5xl leading-tight">{meta.pageTitle}</h1>
      <p class="font-serif italic text-base md:text-lg text-neutral-content/80 max-w-xl">{meta.pageDescription}</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12 md:py-16">
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="flex items-center gap-4 p-5 rounded-lg border border-base-300 hover:border-primary hover:bg-base-200 transition-colors group"
          >
            <span class="shrink-0 inline-flex items-center justify-center w-12 h-12 rounded-full border-2 border-primary text-primary text-2xl group-hover:bg-primary group-hover:text-primary-content transition-colors">
              <Icon name={link.icon} />
            </span>
            <span class="font-serif font-bold text-xl md:text-2xl text-base-content group-hover:text-primary transition-colors">
              {link.label}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>

</BaseLayout>
