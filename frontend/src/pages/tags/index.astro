---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import ShareModal from '../../components/ui/ShareModal.astro';
import { getTags, getContenutiByTagMap } from '../../lib/api/index.js';

const tags = await getTags();
const contenutiMap = await getContenutiByTagMap();
---
<BaseLayout title="Tags" description="L'elenco dei tag con cui sono catalogati i contenuti">

  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Tags' }]} />

      <h1 class="font-serif font-bold text-2xl md:text-3xl text-base-content">Tags</h1>

      <p class="font-serif italic text-base text-base-content/60">L'elenco dei tag con cui sono catalogati i contenuti</p>

      <share-button data-title="Tags" class="contents">
        <button type="button" class="inline-flex items-center gap-1 cursor-pointer w-fit" aria-label="Condividi questa pagina">
          <i class="ph ph-share-network"></i>
          Condividi
        </button>
        <ShareModal />
      </share-button>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <article class="grid grid-cols-2 gap-x-4 gap-y-2 mt-6">
    {tags.map((tag) => {
      const { canti = 0, eventi = 0 } = contenutiMap.get(tag.id) ?? {};
      const parti = [
        canti > 0 && `${canti} ${canti === 1 ? 'canto' : 'canti'}`,
        eventi > 0 && `${eventi} ${eventi === 1 ? 'evento' : 'eventi'}`,
      ].filter(Boolean);

      return (
        <div class="flex flex-col gap-0.5 py-2">
          <a href={`/tags/${tag.slug}`} class="font-serif font-semibold text-primary hover:underline">
            {tag.titolo}
          </a>
          {parti.length > 0 && (
            <p class="font-serif italic text-base text-base-content/60">{parti.join(' · ')}</p>
          )}
        </div>
      );
    })}
  </article>

  <script>
    import '../../scripts/share-button.js';
  </script>
  </div>
</BaseLayout>
