---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import PagefindList from '../../components/ui/PagefindList.astro';
import { getTags } from '../../lib/api/index.js';
import type { Tassonomia } from '../../lib/api/types.js';
import { buildWebPageSchema, buildBreadcrumbSchema } from '../../lib/schema.js';
import { buildCanonical } from '../../lib/seo.js';
import { getPageMeta } from '../../lib/pages.js';
import { getOgImageFallback } from '../../lib/og-image.js';

export async function getStaticPaths() {
  const tags = await getTags();
  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props as { tag: Tassonomia };
const titolo = tag.titolo.charAt(0).toUpperCase() + tag.titolo.slice(1);
const meta = getPageMeta('tags.term', { titolo });
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const jsonLd = [
  buildWebPageSchema(meta.metaTitle, meta.metaDescription, buildCanonical(Astro)),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Tags', url: `${siteUrl}/tags` },
    { name: titolo },
  ]),
];
const ogImage = await getOgImageFallback();
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription} jsonLd={jsonLd} ogImage={ogImage}>

  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-2">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Tags', href: '/tags' }, { label: titolo }]} />
      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>
      <p class="font-serif italic text-base text-base-content/60">{meta.pageDescription}</p>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <div class="mt-6">
    <PagefindList
      presetFilter={{ tags: tag.titolo }}
      filterKeys={["type", "periodi"]}
      pageSize={15}
      sortOptions={[
        { field: 'titolo', label: 'A–Z', dir: 'asc' },
        { field: 'visualizzazioni', label: 'Più visti', dir: 'desc' },
        { field: 'visualizzazioni', label: 'Meno visti', dir: 'asc' },
      ]}
    />
  </div>

  </div>
</BaseLayout>
