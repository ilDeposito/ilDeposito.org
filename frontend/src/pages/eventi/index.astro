---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import HeaderWatermark from '../../components/ui/HeaderWatermark.astro';
import ShareModal from '../../components/ui/ShareModal.astro';
import Icon from '../../components/base/Icon.astro';
import {
  getEventiDelMese,
  getPeriodi,
  getEventiByPeriodo,
  getEventiGeo,
  getImageUrl,
} from '../../lib/api/index.js';
import { buildCollectionPageSchema, buildBreadcrumbSchema, buildItemListSchema } from '../../lib/schema.js';
import { buildCanonical } from '../../lib/seo.js';
import { getPageMeta } from '../../lib/pages.js';

const now   = new Date();
const month = now.getUTCMonth() + 1;

const [eventiMese, periodiRaw, eventiGeo] = await Promise.all([
  getEventiDelMese(month),
  getPeriodi(),
  getEventiGeo(),
]);

const periodi = [...periodiRaw].sort((a, b) => a.sort - b.sort);

const blocchi = (
  await Promise.all(
    periodi.map(async (periodo) => {
      const eventi = await getEventiByPeriodo(periodo.id, 4);
      const eventiConDati = eventi.map((evento) => ({ evento, immagineUrl: getImageUrl(evento.immagine) }));
      return { periodo, eventiConDati };
    })
  )
).filter((b) => b.eventiConDati.length > 0);

const imgUrls = eventiMese.map((e) => getImageUrl(e.immagine));

const todayDay = now.getUTCDate();
const startIndex = (() => {
  const i = eventiMese.findIndex((e) => new Date(e.dataEvento).getUTCDate() >= todayDay);
  return i === -1 ? 0 : i;
})();

const mesiIT = ['gennaio','febbraio','marzo','aprile','maggio','giugno','luglio','agosto','settembre','ottobre','novembre','dicembre'];
const meseNome = mesiIT[month - 1];

const formatData = (data: string) =>
  new Date(data).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });

const meta = getPageMeta('eventi.index');
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const jsonLd = [
  buildCollectionPageSchema(meta.metaTitle, meta.metaDescription, buildCanonical(Astro)),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Eventi' },
  ]),
  ...blocchi.map(({ periodo, eventiConDati }) =>
    buildItemListSchema(
      `Gli eventi più visti del periodo "${periodo.titolo}"`,
      eventiConDati.map(({ evento }) => ({ name: evento.titolo, url: `${siteUrl}/eventi/${evento.slug}` }))
    )
  ),
];

const eventiGeoJson = JSON.stringify(
  eventiGeo.map((e) => ({
    titolo:      e.titolo,
    slug:        e.slug,
    data_evento: e.dataEvento,
    latitude:    e.latitude,
    longitude:   e.longitude,
  }))
);
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription} jsonLd={jsonLd} dnsPrefetch={['https://tile.openstreetmap.org']}>

  <header class="relative overflow-hidden bg-base-200 border-b-2 border-secondary">
    <HeaderWatermark />
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Eventi' }]} />

      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>
      <p class="font-serif italic text-base text-base-content/70">{meta.pageDescription}</p>

      <a href="/eventi/elenco" class="btn btn-primary gap-2 w-fit border-0">
        Tutti gli eventi
        <Icon name="arrow-right" />
      </a>

      <share-button data-title="Gli eventi dell'archivio" class="contents">
        <button type="button" class="inline-flex items-center gap-1 cursor-pointer w-fit" aria-label="Condividi questa pagina">
          <Icon name="share-network" />
          Condividi
        </button>
        <ShareModal pageType="eventi" />
      </share-button>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <article class="flex flex-col gap-8 mt-6">

    <!-- Carousel eventi del mese -->
    {eventiMese.length > 0 && (
      <section class="flex flex-col gap-3">
        <h2 class="font-serif font-bold text-lg md:text-xl text-base-content text-center w-fit mx-auto border-b-2 border-secondary pb-2">
          Gli eventi di {meseNome}
        </h2>

        <image-carousel
          data-initial={String(startIndex)}
          class="block relative max-w-3xl mx-auto w-full"
          role="group"
          aria-roledescription="carosello"
          aria-label="Eventi del mese"
        >
          <span data-carousel-live role="status" class="sr-only"></span>
          <!-- Viewport -->
          <div data-viewport class="overflow-hidden relative">
            <!-- Track -->
            <div data-track class="flex">
              {eventiMese.map((evento, i) => {
                const loc = evento.localizzazioni[0];
                return (
                  <div data-item inert={i !== startIndex} class="min-w-full">
                    <a href={`/eventi/${evento.slug}`} class="block relative h-64">
                      {imgUrls[i] ? (
                        <Image
                          src={imgUrls[i]}
                          alt={"Immagine dell'evento: " + evento.titolo}
                          width={800}
                          height={450}
                          format="webp"
                          quality={75}
                          class="w-full h-full object-cover grayscale"
                          loading={i === startIndex ? 'eager' : 'lazy'}
                        />
                      ) : (
                        <div class="w-full h-full bg-base-300 flex items-center justify-center">
                          <Icon name="image-broken" class="text-4xl text-base-content/50" />
                        </div>
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"></div>
                      <div class="absolute bottom-0 left-0 right-0 p-4 text-white">
                        {loc && evento.dataEvento && (
                          <p class="font-sans text-sm text-white/80 mb-1">
                            {loc.titolo} · {formatData(evento.dataEvento)}
                          </p>
                        )}
                        <p class="font-serif font-bold text-base leading-tight line-clamp-2">{evento.titolo}</p>
                      </div>
                    </a>
                  </div>
                );
              })}
            </div>

            <!-- Frecce -->
            {eventiMese.length > 1 && (
              <>
                <button
                  data-prev
                  type="button"
                  aria-label="Evento precedente"
                  class="absolute left-2 top-1/2 -translate-y-1/2 z-10 btn btn-circle btn-sm bg-black/50 border-0 text-white hover:bg-black/70"
                >
                  <Icon name="arrow-left" class="text-base" />
                </button>
                <button
                  data-next
                  type="button"
                  aria-label="Evento successivo"
                  class="absolute right-2 top-1/2 -translate-y-1/2 z-10 btn btn-circle btn-sm bg-black/50 border-0 text-white hover:bg-black/70"
                >
                  <Icon name="arrow-right" class="text-base" />
                </button>
              </>
            )}
          </div>

          <!-- Dots -->
          {eventiMese.length > 1 && (
            <div class="flex flex-wrap justify-center gap-2 mt-3 px-4">
              {eventiMese.map((_, i) => (
                <button
                  data-dot
                  type="button"
                  aria-label={`Vai all'evento ${i + 1}`}
                  aria-current={i === startIndex ? 'true' : 'false'}
                  class="w-6 h-6 shrink-0 flex items-center justify-center"
                >
                  <span class={`w-2 h-2 rounded-full bg-primary transition-opacity ${i === startIndex ? 'opacity-100' : 'opacity-30'}`}></span>
                </button>
              ))}
            </div>
          )}
        </image-carousel>
      </section>
    )}

    <!-- Eventi più visti per periodo -->
    <div class="flex flex-col gap-12">
      {blocchi.map(({ periodo, eventiConDati }) => (
        <section class="flex flex-col gap-8">
          <h2 class="font-serif font-bold text-lg md:text-xl text-base-content text-center w-fit mx-auto border-b-2 border-secondary pb-2">
            <a href={`/periodi/${periodo.slug}`} class="hover:underline inline-flex items-center gap-2">
              <Icon name="calendar-star" class="text-primary/70" />
              {periodo.titolo}
            </a>
          </h2>

          <ul role="list" class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10">
            {eventiConDati.map(({ evento, immagineUrl }, i) => (
              <li class="flex items-start gap-5 group relative">
                <div class="shrink-0">
                  {immagineUrl ? (
                    <Image
                      src={immagineUrl}
                      alt={"Immagine dell'evento: " + evento.titolo}
                      width={240}
                      height={240}
                      format="webp"
                      quality={80}
                      loading={i < 4 ? 'eager' : 'lazy'}
                      class="w-32 h-32 md:w-36 md:h-36 rounded-full object-cover border-2 border-base-300 grayscale group-hover:grayscale-0 transition-all duration-300"
                    />
                  ) : (
                    <div class="w-32 h-32 md:w-36 md:h-36 rounded-full bg-base-200 flex items-center justify-center border-2 border-base-300">
                      <Icon name="calendar-star" class="text-base-content/50 text-5xl" />
                    </div>
                  )}
                </div>

                <div class="flex flex-col gap-1.5 min-w-0 pt-2">
                  <h3 class="font-serif font-bold text-xl md:text-2xl text-primary leading-tight">
                    <a href={`/eventi/${evento.slug}`} class="hover:underline after:absolute after:inset-0">{evento.titolo}</a>
                  </h3>

                  {evento.dataEvento && (
                    <p class="text-base text-base-content/70 flex items-center gap-2">
                      <Icon name="calendar-blank" class="text-sm shrink-0" />
                      {formatData(evento.dataEvento)}
                    </p>
                  )}

                  {evento.localizzazioni.length > 0 && (
                    <p class="text-base text-base-content/70 flex items-center gap-2 relative z-10">
                      <Icon name="map-pin" class="text-sm shrink-0" />
                      <span>
                        {evento.localizzazioni.map((l, j) => (
                          <>{j > 0 && ', '}<a href={`/localizzazioni/${l.slug}`} class="hover:text-primary hover:underline">{l.titolo}</a></>
                        ))}
                      </span>
                    </p>
                  )}

                  {evento.periodi.length > 0 && (
                    <p class="text-base text-base-content/70 flex items-center gap-2 relative z-10">
                      <Icon name="calendar-star" class="text-sm shrink-0" />
                      <span>
                        {evento.periodi.map((p, j) => (
                          <>{j > 0 && ', '}<a href={`/periodi/${p.slug}`} class="hover:text-primary hover:underline">{p.titolo}</a></>
                        ))}
                      </span>
                    </p>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}

      <a href="/eventi/elenco" class="btn btn-primary self-center gap-2">
        Tutti gli eventi
        <Icon name="arrow-right" />
      </a>
    </div>

    <!-- Mappa degli eventi -->
    {eventiGeo.length > 0 && (
      <section class="flex flex-col gap-3">
        <h2 class="font-serif font-bold text-lg md:text-xl text-base-content text-center w-fit mx-auto border-b-2 border-secondary pb-2">
          Mappa degli eventi
        </h2>
        <events-map
          data-eventi={eventiGeoJson}
          role="region"
          aria-label="Mappa degli eventi"
          class="isolate block w-full rounded-lg overflow-hidden border border-base-300"
          style="height: 24rem;"
        ></events-map>
      </section>
    )}

  </article>

  <script>
    import '../../scripts/share-button.js';
    import '../../scripts/image-carousel.js';
    import '../../scripts/events-map.js';
  </script>
  </div>
</BaseLayout>
