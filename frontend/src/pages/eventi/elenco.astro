---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import HeaderWatermark from '../../components/ui/HeaderWatermark.astro';
import ShareModal from '../../components/ui/ShareModal.astro';
import PagefindList from '../../components/ui/PagefindList.astro';
import Icon from '../../components/base/Icon.astro';
import { getPageMeta } from '../../lib/pages.js';

const meta = getPageMeta('eventi.elenco');
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription}>

  <header class="relative overflow-hidden bg-base-200 border-b-2 border-secondary">
    <HeaderWatermark />
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-6 flex flex-col gap-2">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Eventi', href: '/eventi' }, { label: 'Elenco' }]} />

      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>
      <p class="font-serif italic text-base text-base-content/70">{meta.pageDescription}</p>

      <a href="/archivio/storia-cantata" class="inline-flex items-center gap-2 text-primary w-fit">
        <span class="border border-primary rounded p-1 inline-flex">
          <Icon name="calendar-star" />
        </span>
        <span class="font-serif italic font-bold uppercase text-sm">La Storia Cantata</span>
      </a>

      <div class="flex items-center gap-4 text-sm text-base-content mt-1">
        <share-button data-title="Gli eventi dell'archivio" class="contents">
          <button type="button" class="inline-flex items-center gap-1 cursor-pointer" aria-label="Condividi questa pagina">
            <Icon name="share-network" />
            Condividi
          </button>
          <ShareModal pageType="eventi" />
        </share-button>
      </div>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <div class="mt-6">
    <PagefindList
      type="eventi"
      filterKeys={["localizzazioni", "tags", "periodi"]}
      pageSize={15}
      sortOptions={[
        { field: 'titolo', label: 'A–Z', dir: 'asc' },
        { field: 'data_evento', label: 'Cronologico', dir: 'asc' },
        { field: 'visualizzazioni', label: 'Più visti', dir: 'desc' },
        { field: 'visualizzazioni', label: 'Meno visti', dir: 'asc' },
      ]}
    />
  </div>

  <script>
    import '../../scripts/share-button.js';
  </script>
  </div>
</BaseLayout>
