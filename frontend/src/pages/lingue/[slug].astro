---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import PagefindList from '../../components/ui/PagefindList.astro';
import { getLingue } from '../../lib/api/index.js';
import type { Tassonomia } from '../../lib/api/types.js';

export async function getStaticPaths() {
  const lingue = await getLingue();
  return lingue.map((lingua) => ({
    params: { slug: lingua.slug },
    props: { lingua },
  }));
}

const { lingua } = Astro.props as { lingua: Tassonomia };
const titolo = lingua.titolo.charAt(0).toUpperCase() + lingua.titolo.slice(1);
---
<BaseLayout title={titolo} description={`I contenuti in ${titolo} dell'archivio`}>

  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-2">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Lingue', href: '/lingue' }, { label: titolo }]} />
      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">{titolo}</h1>
      <p class="font-serif italic text-base text-base-content/60">I contenuti in {titolo} dell'archivio</p>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <div class="mt-6">
    <PagefindList
      presetFilter={{ lingue: lingua.titolo }}
      filterKeys={["type", "periodi"]}
      pageSize={15}
    />
  </div>

  </div>
</BaseLayout>
