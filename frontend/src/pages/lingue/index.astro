---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import HeaderWatermark from '../../components/ui/HeaderWatermark.astro';
import ShareModal from '../../components/ui/ShareModal.astro';
import Icon from '../../components/base/Icon.astro';
import { getLingue, getContenutiByLinguaMap } from '../../lib/api/index.js';
import { buildCollectionPageSchema, buildBreadcrumbSchema } from '../../lib/schema.js';
import { buildCanonical } from '../../lib/seo.js';
import { getPageMeta } from '../../lib/pages.js';

const lingue = await getLingue();
const contenutiMap = await getContenutiByLinguaMap();

const meta = getPageMeta('lingue.index');
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://www.ildeposito.org';
const jsonLd = [
  buildCollectionPageSchema(meta.metaTitle, meta.metaDescription, buildCanonical(Astro)),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Lingue' },
  ]),
];
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription} jsonLd={jsonLd}>

  <!-- Titolo + info: attaccato all'header e ai bordi laterali -->
  <header class="relative overflow-hidden bg-base-200 border-b-2 border-secondary">
    <HeaderWatermark />
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Lingue' }]} />

      <h1 class="font-serif font-bold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>

      <p class="font-serif italic text-base text-base-content/60">{meta.pageDescription}</p>

      <share-button data-title="Lingue" class="contents">
        <button type="button" class="inline-flex items-center gap-1 cursor-pointer w-fit" aria-label="Condividi questa pagina">
          <Icon name="share-network" />
          Condividi
        </button>
        <ShareModal pageType="lingue" />
      </share-button>
    </div>
  </header>
  <div class="max-w-6xl mx-auto px-4 py-8">

  <article class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto mt-6">
    {lingue.map((lingua) => {
      const { canti = 0, traduzioni = 0 } = contenutiMap.get(lingua.id) ?? {};
      const parti = [
        canti > 0 && `${canti} ${canti === 1 ? 'canto' : 'canti'}`,
        traduzioni > 0 && `${traduzioni} ${traduzioni === 1 ? 'traduzione' : 'traduzioni'}`,
      ].filter(Boolean);

      return (
        <div class="flex flex-col gap-0.5 py-2">
          <a href={`/lingue/${lingua.slug}`} class="font-serif font-semibold text-primary capitalize hover:underline">
            {lingua.titolo}
          </a>
          {parti.length > 0 && (
            <p class="font-serif italic text-base text-base-content/60">{parti.join(' · ')}</p>
          )}
        </div>
      );
    })}
  </article>

  <script>
    import '../../scripts/share-button.js';
  </script>
  </div>
</BaseLayout>
