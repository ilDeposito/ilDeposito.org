---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import HeaderWatermark from '../../components/ui/HeaderWatermark.astro';
import ShareModal from '../../components/ui/ShareModal.astro';
import Icon from '../../components/base/Icon.astro';
import MonthCalendar from '../../components/ui/MonthCalendar.astro';
import { getEventiCalendario } from '../../lib/api/index.js';
import { getPageMeta } from '../../lib/pages.js';

const meta = getPageMeta('calendario.index');
const eventi = await getEventiCalendario();

const eventsByMonth = new Map<number, Set<number>>();
for (let m = 1; m <= 12; m++) eventsByMonth.set(m, new Set());

for (const evento of eventi) {
  const d = new Date(evento.dataEvento);
  const month = d.getUTCMonth() + 1;
  const day = d.getUTCDate();
  eventsByMonth.get(month)!.add(day);
}

const year = new Date().getFullYear();
---
<BaseLayout title={meta.metaTitle} description={meta.metaDescription}>

  <header class="relative overflow-hidden bg-base-200 border-b-2 border-secondary">
    <HeaderWatermark />
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Eventi', href: '/eventi' }, { label: 'Calendario cantato' }]} />

      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>
      <p class="font-serif italic text-base text-base-content/60">{meta.pageDescription}</p>

      <share-button data-title="Calendario cantato" class="contents">
        <button type="button" class="inline-flex items-center gap-1 cursor-pointer w-fit" aria-label="Condividi questa pagina">
          <Icon name="share-network" />
          Condividi
        </button>
        <ShareModal pageType="calendario" />
      </share-button>
    </div>
  </header>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {Array.from({ length: 12 }, (_, i) => i + 1).map((month) => (
        <div class="bg-base-200 rounded-lg p-4">
          <MonthCalendar
            month={month}
            year={year}
            highlightedDays={Array.from(eventsByMonth.get(month)!)}
          />
        </div>
      ))}
    </div>
  </div>

  <script>
    import '../../scripts/share-button.js';
  </script>
</BaseLayout>
