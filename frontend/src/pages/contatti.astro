---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { getPageMeta } from '../lib/pages.js';

const meta = getPageMeta('contatti');
---
<BaseLayout
  title={meta.metaTitle}
  description={meta.metaDescription}
  noindex={meta.noindex}
>
  <header class="bg-base-200 border-b-2 border-secondary">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col gap-3">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Contatti' }]} />
      <h1 class="font-serif font-semibold text-2xl md:text-3xl text-base-content">{meta.pageTitle}</h1>
      <p class="font-sans text-base-content/70">{meta.pageDescription}</p>
    </div>
  </header>

  <div class="max-w-2xl mx-auto px-4 py-10">

    <div class="font-sans text-base-content/80 leading-relaxed mb-8 flex flex-col gap-3">
      <p>
        Per contattarci potete scriverci all'indirizzo email
        <a href="mailto:info@ildeposito.org" class="link link-primary font-semibold">info@ildeposito.org</a>.
      </p>
      <p>In alternativa, potete compilare il modulo sottostante.</p>
    </div>

    <div id="form-error" role="alert" class="alert alert-error mb-8 hidden">
      <i class="ph ph-warning-circle text-xl"></i>
      <span id="form-error-msg">Si è verificato un errore durante l'invio. Riprova più tardi.</span>
    </div>

    <form id="contatti-form" action="/api/modulo_contatti" method="post" class="flex flex-col gap-5" novalidate>

      <input type="hidden" name="titolo" value="Modulo contatti" />

      <!-- Honeypot: campo invisibile compilato solo dai bot -->
      <div aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;">
        <label for="website">Non compilare</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <div class="form-control">
        <label class="label" for="nome">
          <span class="label-text font-semibold">Nome <span class="text-error" aria-hidden="true">*</span></span>
        </label>
        <input
          type="text"
          id="nome"
          name="nome"
          required
          maxlength="255"
          autocomplete="name"
          class="input input-bordered form-border bg-base-200 w-full"
          placeholder="Il tuo nome"
        />
      </div>

      <div class="form-control">
        <label class="label" for="email">
          <span class="label-text font-semibold">Email <span class="text-error" aria-hidden="true">*</span></span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          maxlength="254"
          autocomplete="email"
          class="input input-bordered form-border bg-base-200 w-full"
          placeholder="la-tua@email.it"
        />
      </div>

      <div class="form-control">
        <label class="label" for="messaggio">
          <span class="label-text font-semibold">Messaggio <span class="text-error" aria-hidden="true">*</span></span>
        </label>
        <textarea
          id="messaggio"
          name="messaggio"
          required
          rows="6"
          class="textarea textarea-bordered form-border bg-base-200 w-full font-sans text-base leading-relaxed"
          placeholder="Scrivi il tuo messaggio…"
        ></textarea>
        <div class="label">
          <span class="label-text-alt text-base-content/50">
            <span id="messaggio-count">0</span>/200 righe
          </span>
        </div>
      </div>

      <!-- Altcha: proof-of-work antispam, self-hosted, zero dati a terzi -->
      <altcha-widget challenge="/api/altcha" hidefooter></altcha-widget>

      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-3" for="privacy">
          <input
            type="checkbox"
            id="privacy"
            name="privacy"
            class="checkbox checkbox-primary form-border shrink-0"
          />
          <span class="label-text">
            Ho letto e accetto la
            <a href="/privacy" class="link link-primary font-semibold">Privacy Policy</a>
            <span class="text-error" aria-hidden="true"> *</span>
          </span>
        </label>
      </div>

      <div class="mt-2">
        <button id="submit-btn" type="submit" class="btn btn-primary w-full sm:w-auto">
          <i class="ph ph-paper-plane-tilt"></i>
          <span id="submit-label">Invia messaggio</span>
        </button>
      </div>

    </form>
  </div>

  <!-- Modal successo (DaisyUI v5) -->
  <dialog id="modal-successo" class="modal">
    <div class="modal-box">
      <div class="flex items-center gap-3 mb-4">
        <i class="ph ph-check-circle text-3xl text-success"></i>
        <h3 class="font-serif font-bold text-lg">Messaggio inviato!</h3>
      </div>
      <p class="font-sans text-base-content/80">
        Grazie per averci scritto. Ti risponderemo il prima possibile.
      </p>
      <div class="modal-action">
        <form method="dialog">
          <button class="btn btn-primary">Chiudi</button>
        </form>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>chiudi</button>
    </form>
  </dialog>

</BaseLayout>

<script>
  // Registra <altcha-widget> come custom element (bundlato da Vite, zero CDN esterni)
  import 'altcha';
</script>

<script is:inline>
(function () {
  const form = document.getElementById('contatti-form');
  const submitBtn = document.getElementById('submit-btn');
  const submitLabel = document.getElementById('submit-label');
  const errorBox = document.getElementById('form-error');
  const errorMsg = document.getElementById('form-error-msg');
  const modal = document.getElementById('modal-successo');
  const privacyCheck = document.getElementById('privacy');
  const emailInput = document.getElementById('email');
  const messaggioArea = document.getElementById('messaggio');
  const messaggioCount = document.getElementById('messaggio-count');

  // Contatore righe textarea
  messaggioArea.addEventListener('input', function () {
    const lines = this.value === '' ? 0 : this.value.split('\n').length;
    messaggioCount.textContent = lines;
    const isOver = lines > 200;
    messaggioCount.classList.toggle('text-error', isOver);
    messaggioCount.classList.toggle('font-semibold', isOver);
  });

  function setLoading(loading) {
    submitBtn.disabled = loading;
    submitLabel.textContent = loading ? 'Invio in corso…' : 'Invia messaggio';
    if (loading) {
      submitBtn.classList.add('loading', 'loading-spinner');
    } else {
      submitBtn.classList.remove('loading', 'loading-spinner');
    }
  }

  function showError(msg) {
    errorMsg.textContent = msg;
    errorBox.classList.remove('hidden');
    errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function hideError() {
    errorBox.classList.add('hidden');
  }

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    hideError();

    const fd = new FormData(form);
    const privacyAccettata = privacyCheck.checked;
    const nome = String(fd.get('nome') || '').trim();
    const messaggio = String(fd.get('messaggio') || '').trim();

    // --- Validazione campi ---
    if (nome.length < 2) {
      showError('Il nome deve contenere almeno 2 caratteri.');
      return;
    }
    if (!emailInput.checkValidity()) {
      showError('Inserisci un indirizzo email valido.');
      return;
    }
    const righe = messaggio === '' ? 0 : messaggio.split('\n').length;
    if (righe > 200) {
      showError(`Il messaggio non può superare le 200 righe (attualmente ${righe}).`);
      return;
    }

    if (!privacyAccettata) {
      showError('Devi accettare la Privacy Policy per inviare il modulo.');
      return;
    }

    if (!fd.get('altcha')) {
      showError('Completa la verifica antispam prima di inviare.');
      return;
    }

    setLoading(true);

    let data;
    try {
      const res = await fetch('/api/modulo_contatti', { method: 'POST', body: fd });
      data = await res.json();
    } catch (err) {
      setLoading(false);
      showError('Errore di rete. Controlla la connessione e riprova.');
      return;
    }

    setLoading(false);

    if (data.ok) {
      form.reset();
      modal.showModal();
    } else {
      const messaggi = {
        campi_mancanti: 'Compila tutti i campi richiesti.',
        nome_troppo_corto: 'Il nome deve contenere almeno 2 caratteri.',
        email_non_valida: 'Inserisci un indirizzo email valido.',
        messaggio_troppo_lungo: 'Il messaggio non può superare le 200 righe.',
        verifica_fallita: 'Verifica antispam non valida. Ricarica la pagina e riprova.',
        privacy_non_accettata: 'Devi accettare la Privacy Policy per inviare il modulo.',
        invio_fallito: "Si è verificato un errore durante l'invio. Riprova più tardi.",
      };
      const msg = messaggi[data.error] ?? "Si è verificato un errore. Riprova più tardi.";
      showError(msg);
    }
  });
})();
</script>
